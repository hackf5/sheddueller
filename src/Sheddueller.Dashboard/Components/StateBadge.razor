@if (Href is null)
{
    <span class="@CssClass" title="@Title" aria-label="@AriaLabel">
        @if (RenderDot)
        {
            <span class="@DotClass" aria-hidden="true"></span>
        }
        @State
    </span>
}
else
{
    <a class="@CssClass" href="@Href" title="@Title" aria-label="@AriaLabel">
        @if (RenderDot)
        {
            <span class="@DotClass" aria-hidden="true"></span>
        }
        @State
    </a>
}

@code {
    [Parameter]
    public JobState State { get; set; }

    [Parameter]
    public string BaseClass { get; set; } = "sd-state-badge";

    [Parameter]
    public string? DotClass { get; set; }

    [Parameter]
    public bool RenderDot { get; set; } = true;

    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    private string CssClass
      => string.Concat(this.BaseClass, " ", this.BaseClass, "--", DashboardFormat.StateCssModifier(this.State));
}
