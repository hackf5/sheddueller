@if (Progress?.Percent is not { } percent)
{
    <span class="@TextClass">@(Progress?.Message ?? EmptyText)</span>
}
else
{
    var clampedPercent = Math.Clamp(percent, 0, 100);

    <div class="@BaseClass">
        <div class="@TrackClass" aria-hidden="true">
            <div class="@BarClass" style="@CreateWidthStyle(clampedPercent)"></div>
        </div>
        <span class="@TextClass">@DashboardFormat.ProgressText(Progress, EmptyText)</span>
    </div>
}

@code {
    [Parameter]
    public JobProgressSnapshot? Progress { get; set; }

    [Parameter]
    public string EmptyText { get; set; } = "N/A";

    [Parameter]
    public string BaseClass { get; set; } = "sd-progress";

    private string TrackClass
      => string.Concat(this.BaseClass, "__track");

    private string BarClass
      => string.Concat(this.BaseClass, "__bar");

    private string TextClass
      => string.Concat(this.BaseClass, "-text");

    private static string CreateWidthStyle(double percent)
      => string.Create(CultureInfo.InvariantCulture, $"width: {percent:0.##}%");
}
