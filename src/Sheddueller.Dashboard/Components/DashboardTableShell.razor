<section class="sd-table-shell">
    <div class="sd-table-toolbar">
        <h2>@Title</h2>
        @if (Toolbar is not null)
        {
            <div class="sd-table-controls">
                @Toolbar
            </div>
        }
    </div>

    <div class="sd-table-wrap">
        @ChildContent
    </div>

    <footer class="sd-table-pagination">
        <span>@ResultText</span>
        @if (ShowLoadMore)
        {
            <button class="sd-table-load-more-button" type="button" @onclick="OnLoadMore" disabled="@IsLoadingMore">
                @(IsLoadingMore ? LoadingMoreText : LoadMoreText)
            </button>
        }
    </footer>
</section>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? Toolbar { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string ResultText { get; set; } = string.Empty;

    [Parameter]
    public bool ShowLoadMore { get; set; }

    [Parameter]
    public bool IsLoadingMore { get; set; }

    [Parameter]
    public string LoadMoreText { get; set; } = "Load More Records";

    [Parameter]
    public string LoadingMoreText { get; set; } = "Loading Records";

    [Parameter]
    public EventCallback OnLoadMore { get; set; }
}
