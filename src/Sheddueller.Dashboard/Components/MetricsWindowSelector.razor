<div class="metrics-window-tabs" role="group" aria-label="Metric window">
    @foreach (var window in _currentWindows)
    {
        <button class="@WindowButtonClass(window)" type="button" aria-pressed="@AriaPressed(window)" @onclick="@(() => SelectWindowAsync(window))">
            @WindowLabel(window)
        </button>
    }
</div>

@code {
    private TimeSpan[] _currentWindows = [];
    private TimeSpan[] _renderedWindows = [];
    private TimeSpan _renderedSelectedWindow;
    private bool _hasRendered;
    private bool _shouldRender = true;

    [Parameter]
    public IReadOnlyList<TimeSpan> Windows { get; set; } = [];

    [Parameter]
    public TimeSpan SelectedWindow { get; set; }

    [Parameter]
    public EventCallback<TimeSpan> SelectedWindowChanged { get; set; }

    protected override void OnParametersSet()
    {
        this._currentWindows = [.. this.Windows];
        this._shouldRender = !this._hasRendered
          || this.SelectedWindow != this._renderedSelectedWindow
          || !this._currentWindows.SequenceEqual(this._renderedWindows);
    }

    protected override bool ShouldRender()
      => this._shouldRender;

    protected override void OnAfterRender(bool firstRender)
    {
        this._hasRendered = true;
        this._renderedSelectedWindow = this.SelectedWindow;
        this._renderedWindows = this._currentWindows;
    }

    private async Task SelectWindowAsync(TimeSpan window)
    {
        if (window == this.SelectedWindow)
        {
            return;
        }

        await this.SelectedWindowChanged.InvokeAsync(window);
    }

    private string WindowButtonClass(TimeSpan window)
      => window == this.SelectedWindow
        ? "metrics-window-tabs__button metrics-window-tabs__button--selected"
        : "metrics-window-tabs__button";

    private string AriaPressed(TimeSpan window)
      => window == this.SelectedWindow ? "true" : "false";

    private static string WindowLabel(TimeSpan window)
    {
        if (window == TimeSpan.FromMinutes(5))
        {
            return "5m";
        }

        if (window == TimeSpan.FromHours(1))
        {
            return "1h";
        }

        if (window == TimeSpan.FromHours(24))
        {
            return "24h";
        }

        return window.TotalHours >= 1
          ? string.Create(CultureInfo.InvariantCulture, $"{window.TotalHours:0.#}h")
          : string.Create(CultureInfo.InvariantCulture, $"{window.TotalMinutes:0.#}m");
    }
}
