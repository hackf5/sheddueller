@implements IAsyncDisposable

<div class="sd-live-status @_statusClass" aria-live="polite">
    <span class="sd-live-status__dot" aria-hidden="true"></span>
    <span>@_statusText</span>
</div>

@code {
    private static readonly TimeSpan DefaultUpdateInterval = TimeSpan.FromSeconds(15);

    private readonly CancellationTokenSource _timerCancellation = new();
    private string _renderedStatusClass = string.Empty;
    private string _renderedStatusText = string.Empty;
    private string _statusClass = string.Empty;
    private string _statusText = string.Empty;
    private DateTimeOffset _nowUtc = DateTimeOffset.UtcNow;
    private PeriodicTimer? _timer;
    private Task? _timerTask;
    private bool _disposed;
    private bool _hasRendered;
    private bool _shouldRender = true;

    [Parameter]
    public bool IsRefreshing { get; set; }

    [Parameter]
    public bool ShowRefreshing { get; set; } = true;

    [Parameter]
    public string? RefreshError { get; set; }

    [Parameter]
    public DateTimeOffset? LastUpdatedUtc { get; set; }

    [Parameter]
    public TimeSpan UpdateInterval { get; set; } = DefaultUpdateInterval;

    protected override void OnParametersSet()
    {
        this._nowUtc = DateTimeOffset.UtcNow;
        this.UpdateStatus();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            this._timer = new PeriodicTimer(this.UpdateInterval);
            this._timerTask = this.RunTimerAsync(this._timer, this._timerCancellation.Token);
        }

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        this._disposed = true;
        await this._timerCancellation.CancelAsync();
        this._timer?.Dispose();

        if (this._timerTask is not null)
        {
            await this._timerTask;
        }

        this._timerCancellation.Dispose();
    }

    private void UpdateStatus()
    {
        var isRefreshing = this.ShowRefreshing && this.IsRefreshing;
        this._statusClass = DashboardFormat.LiveStatusClass(isRefreshing, this.RefreshError);
        this._statusText = DashboardFormat.LiveStatusText(isRefreshing, this.RefreshError, this.LastUpdatedUtc, this._nowUtc);
        this._shouldRender = !this._hasRendered
          || this._statusClass != this._renderedStatusClass
          || this._statusText != this._renderedStatusText;
    }

    protected override bool ShouldRender()
      => this._shouldRender;

    protected override void OnAfterRender(bool firstRender)
    {
        this._hasRendered = true;
        this._renderedStatusClass = this._statusClass;
        this._renderedStatusText = this._statusText;
    }

    private async Task RunTimerAsync(
        PeriodicTimer timer,
        CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await this.InvokeAsync(() =>
                {
                    if (!this._disposed)
                    {
                        this._nowUtc = DateTimeOffset.UtcNow;
                        this.UpdateStatus();
                        this.StateHasChanged();
                    }
                });
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }
}
