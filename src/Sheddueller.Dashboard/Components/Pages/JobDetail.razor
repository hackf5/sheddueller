@page "/jobs/{JobId:guid}"
@inherits DashboardPageComponent
@using Microsoft.JSInterop
@inject IJobInspectionReader Reader
@inject IJobManager JobManager
@inject DashboardLiveUpdateStream LiveUpdates
@inject IJSRuntime JsRuntime

<div class="job-detail-page">
    <header class="job-detail-toolbar">
        <div class="job-detail-toolbar__primary">
            <a class="job-detail-back-link" href="jobs">
                <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
                <span>Jobs</span>
            </a>
            <span class="job-detail-toolbar__title">Job Detail</span>
        </div>

        <div class="job-detail-actions" title="@CancelButtonTitle">
            <button class="@CancelButtonClass" type="button" title="@CancelButtonTitle"
                    aria-label="@CancelButtonAriaLabel" @onclick="CancelJobAsync" disabled="@IsCancelButtonDisabled">
                <span class="material-symbols-outlined" aria-hidden="true">@CancelButtonIcon</span>
                <span>@CancelButtonText</span>
            </button>
        </div>
    </header>

    @if (_actionMessage is not null)
    {
        <DashboardInlineAlert CssClass="@ActionAlertClass" Icon="@ActionAlertIcon">
            <span>@_actionMessage</span>
        </DashboardInlineAlert>
    }

    @if (_error is not null)
    {
        <section class="job-detail-message job-detail-message--error" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">error</span>
            <div>
                <h1>Job detail failed to load</h1>
                <p>@_error</p>
            </div>
        </section>
    }
    else if (_isLoading && _detail is null)
    {
        <section class="job-detail-message" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">progress_activity</span>
            <div>
                <h1>Loading job detail</h1>
                <p>Reading scheduler job record and durable events.</p>
            </div>
        </section>
    }
    else if (_detail is null)
    {
        <section class="job-detail-not-found-canvas" aria-live="polite">
            <div class="job-detail-not-found-card">
                <div class="job-detail-not-found-card__icon" aria-hidden="true">
                    <span class="material-symbols-outlined">search_off</span>
                </div>

                <h1>Job Not Found</h1>
                <p>
                    The requested execution record could not be located. No job found with ID:
                    <span class="job-detail-not-found-card__id">@DashboardFormat.JobId(JobId)</span>
                </p>

                <a class="job-detail-not-found-card__action" href="jobs">
                    <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
                    <span>Return to Jobs</span>
                </a>
            </div>
        </section>
    }
    else
    {
        var job = _detail.Summary;
        var lifecycleEvents = GetLifecycleEvents();
        var logEvents = GetLogEvents();

        @if (LiveRefresh.RefreshError is not null)
        {
            <DashboardInlineAlert CssClass="job-detail-inline-alert job-detail-inline-alert--error" Icon="warning">
                <span>Refresh failed: @LiveRefresh.RefreshError</span>
            </DashboardInlineAlert>
        }

        <section class="job-detail-hero">
            <div class="job-detail-hero__main">
                <div class="job-detail-identity">
                    <div class="job-detail-title-row">
                        <h1>@DashboardFormat.JobId(job.JobId)</h1>
                        <StateBadge BaseClass="job-detail-state" DotClass="job-detail-state__dot" State="job.State"
                                    Href="@StateFilterHref(job.State)" Title="@StateFilterTitle(job.State)"
                                    AriaLabel="@StateFilterTitle(job.State)" />
                    </div>
                    <p>
                        Handler:
                            <a class="job-detail-handler job-detail-filter-link"
                               href="@HandlerFilterHref(job)"
                               title="@DashboardFormat.FullHandler(job)"
                               aria-label="@HandlerFilterTitle(job)">@DashboardFormat.FullHandler(job)</a>
                    </p>
                </div>
            </div>

            <div class="job-detail-summary-grid">
                <div class="job-detail-summary-block">
                    <span class="job-detail-label">Progress</span>
                    <div class="job-detail-progress-line">
                        <div class="job-detail-progress-track" aria-hidden="true">
                            <span class="job-detail-progress-bar" style="@DashboardFormat.ProgressWidthStyle(job.LatestProgress)"></span>
                        </div>
                        <span class="job-detail-progress-percent">@DashboardFormat.ProgressPercent(job.LatestProgress)</span>
                    </div>
                    <span class="job-detail-muted">@DashboardFormat.ProgressText(job.LatestProgress)</span>
                </div>

                <div class="job-detail-summary-block job-detail-summary-block--ruled">
                    <span class="job-detail-label">Timestamps</span>
                    <div class="job-detail-timestamp-pair">
                        <div>
                            <span>Started:</span>
                            <TimestampBlock BaseClass="job-detail-inline-timestamp" Value="GetStartedAt(_detail)"
                                            AllowFutureRelative="false" />
                        </div>
                        <span class="job-detail-mono job-detail-muted">@DashboardFormat.Utc(GetStartedAt(_detail))</span>
                    </div>
                    <div class="job-detail-timestamp-pair">
                        <div>
                            <span>Run Time:</span>
                            <strong class="job-detail-inline-duration">@DashboardFormat.RunTime(_detail)</strong>
                        </div>
                        <span class="job-detail-mono job-detail-muted">@DashboardFormat.Utc(DashboardFormat.TerminalTimestamp(job))</span>
                    </div>
                </div>

                <div class="job-detail-summary-block job-detail-summary-block--ruled">
                    <span class="job-detail-label">Disposition</span>
                    <span class="job-detail-disposition @GetDispositionClass(job)">@DashboardFormat.Disposition(job)</span>
                </div>
            </div>
        </section>

        <div class="job-detail-content-grid">
            <section class="job-detail-panel job-detail-metadata-panel">
                <h2>Metadata</h2>

                <div class="job-detail-metadata-list">
                    <div class="job-detail-metadata-item">
                        <span>Priority</span>
                        <strong>@job.Priority.ToString(CultureInfo.InvariantCulture)</strong>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Attempts</span>
                        <strong class="@(job.AttemptCount > 1 ? "job-detail-text-warning" : null)">@DashboardFormat.Attempts(job)</strong>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Enqueue Seq</span>
                        <strong>@job.EnqueueSequence.ToString(CultureInfo.InvariantCulture)</strong>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Queue Position</span>
                        <strong title="@DashboardFormat.QueuePosition(job.QueuePosition)">@DashboardFormat.QueuePosition(job.QueuePosition)</strong>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Source Schedule Key</span>
                        <strong title="@DashboardFormat.Nullable(job.SourceScheduleKey)">@DashboardFormat.Nullable(job.SourceScheduleKey)</strong>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Claimed Node ID</span>
                        <strong title="@DashboardFormat.Nullable(_detail.ClaimedByNodeId)">@DashboardFormat.Nullable(_detail.ClaimedByNodeId)</strong>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Lease Expiration</span>
                        <div class="job-detail-stacked-value">
                            <TimestampBlock BaseClass="job-detail-value-timestamp" Value="_detail.LeaseExpiresAtUtc" />
                        </div>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Enqueued</span>
                        <div class="job-detail-stacked-value">
                            <TimestampBlock BaseClass="job-detail-value-timestamp" Value="job.EnqueuedAtUtc"
                                            AllowFutureRelative="false" />
                        </div>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Not Before</span>
                        <div class="job-detail-stacked-value">
                            <TimestampBlock BaseClass="job-detail-value-timestamp" Value="job.NotBeforeUtc" />
                        </div>
                    </div>
                    <div class="job-detail-metadata-item">
                        <span>Scheduled Fire</span>
                        <div class="job-detail-stacked-value">
                            <TimestampBlock BaseClass="job-detail-value-timestamp" Value="_detail.ScheduledFireAtUtc"
                                            AllowFutureRelative="false" />
                        </div>
                    </div>
                </div>

                <div class="job-detail-chip-section">
                    <span class="job-detail-label">Tags</span>
                    <TagChipList ClassPrefix="job-detail-chip" Tags="job.Tags" HrefFactory="TagFilterHref"
                                 LinkAriaLabelPrefix="Filter jobs by tag" />
                </div>

                <div class="job-detail-chip-section">
                    <span class="job-detail-label">Groups</span>
                    <ChipList ClassPrefix="job-detail-chip" Values="job.ConcurrencyGroupKeys"
                              Title="@DashboardFormat.GroupKeysTitle(job.ConcurrencyGroupKeys)"
                              HrefFactory="GroupFilterHref"
                              LinkAriaLabelPrefix="Filter jobs by group" />
                </div>
            </section>

            <div class="job-detail-operations">
                @if (_detail.Invocation is { } invocation)
                {
                    <section class="job-detail-panel job-detail-invocation-panel">
                        <h2>Invocation</h2>

                        <pre class="job-detail-invocation-call language-csharp"><code class="language-csharp"
                                                                                       @ref="_invocationCodeElement">@invocation.ReconstructedCall</code></pre>

                        <div class="job-detail-invocation-summary">
                            <div class="job-detail-metadata-item">
                                <span>Handler</span>
                                <strong title="@DashboardFormat.FullHandler(job)">@DashboardFormat.InvocationHandler(invocation)</strong>
                            </div>
                            <div class="job-detail-metadata-item">
                                <span>Target</span>
                                <strong>@invocation.TargetKind.ToString()</strong>
                            </div>
                            <div class="job-detail-metadata-item">
                                <span>Payload</span>
                                <strong title="@invocation.SerializedArgumentsContentType">@DashboardFormat.Count(invocation.SerializedArgumentsByteCount) bytes</strong>
                            </div>
                        </div>

                        @if (invocation.SerializedArgumentsStatus != JobSerializedArgumentsInspectionStatus.Displayable)
                        {
                            <p class="job-detail-empty">@DashboardFormat.InvocationStatus(invocation)</p>
                        }

                        <div class="job-detail-parameter-list">
                            @foreach (var parameter in invocation.Parameters)
                            {
                                <article class="job-detail-parameter" @key="parameter.ParameterIndex">
                                    <div class="job-detail-parameter__header">
                                        <span>@string.Create(CultureInfo.InvariantCulture, $"#{parameter.ParameterIndex + 1}")</span>
                                        <strong title="@parameter.ParameterType">@DashboardFormat.ShortTypeName(parameter.ParameterType)</strong>
                                        <em>@DashboardFormat.InvocationBinding(parameter)</em>
                                    </div>

                                    @if (parameter.SerializedValueJson is not null)
                                    {
                                        <pre>@parameter.SerializedValueJson</pre>
                                    }
                                </article>
                            }
                        </div>
                    </section>
                }

                <section class="job-detail-panel">
                    <h2>Lifecycle Timeline</h2>

                    @if (lifecycleEvents.Count == 0)
                    {
                        <p class="job-detail-empty">No lifecycle events have been recorded.</p>
                    }
                    else
                    {
                        <div class="job-detail-timeline">
                            @foreach (var jobEvent in lifecycleEvents)
                            {
                                <article class="@DashboardFormat.TimelineItemClass(jobEvent)" @key="jobEvent.EventId">
                                    <span class="job-detail-timeline__dot" aria-hidden="true"></span>
                                    <div class="job-detail-timeline__content">
                                        <p>@DashboardFormat.TimelineTitle(jobEvent)</p>
                                        @if (DashboardFormat.ShouldRenderTimelineMessage(jobEvent))
                                        {
                                            <span>@jobEvent.Message</span>
                                        }
                                    </div>
                                    <div class="job-detail-timeline__time">
                                        <TimestampBlock BaseClass="job-detail-event-timestamp" Value="jobEvent.OccurredAtUtc"
                                                        AllowFutureRelative="false" />
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </section>

                <section class="job-detail-panel job-detail-log-panel">
                    <div class="job-detail-log-header">
                        <div>
                            <h2>Log Stream</h2>
                        </div>

                        <div class="job-detail-log-actions">
                            <label class="job-detail-switch">
                                <input type="checkbox" checked="@_showProgressLogs" @onchange="ToggleProgressLogs" />
                                <span aria-hidden="true"></span>
                                <strong>Show Progress</strong>
                            </label>
                            <button class="job-detail-button job-detail-button--secondary job-detail-button--compact" type="button" @onclick="ToggleLogsPaused">
                                <span class="material-symbols-outlined" aria-hidden="true">@(_logsPaused ? "play_arrow" : "pause")</span>
                                <span>@(_logsPaused ? "Resume" : "Pause")</span>
                            </button>
                            <div class="job-detail-stream-status @(_logsPaused ? "job-detail-stream-status--paused" : null)">
                                <span aria-hidden="true"></span>
                                <strong>@(_logsPaused ? "PAUSED" : "LIVE")</strong>
                            </div>
                            <button class="job-detail-icon-button" type="button" disabled aria-label="Download logs" title="Download logs">
                                <span class="material-symbols-outlined" aria-hidden="true">download</span>
                            </button>
                        </div>
                    </div>

                    <div class="job-detail-log-table-wrap">
                        <table class="job-detail-log-table">
                            <thead>
                                <tr>
                                    <th>Att</th>
                                    <th>Level</th>
                                    <th>Time</th>
                                    <th>Message</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (logEvents.Count == 0)
                                {
                                    <tr>
                                        <td class="job-detail-empty-row" colspan="4">@GetLogEmptyMessage()</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var jobEvent in logEvents)
                                    {
                                        <tr class="@GetLogRowClass(jobEvent, logEvents)" @key="jobEvent.EventId">
                                            <td>@jobEvent.AttemptNumber.ToString(CultureInfo.InvariantCulture)</td>
                                            <td>
                                                <span class="@DashboardFormat.LogLevelClass(jobEvent)">@DashboardFormat.LogLevel(jobEvent)</span>
                                            </td>
                                            <td>
                                                <div class="job-detail-log-time">
                                                    <TimestampBlock BaseClass="job-detail-log-timestamp" Value="jobEvent.OccurredAtUtc"
                                                                    AllowFutureRelative="false" />
                                                    <span>@DashboardFormat.UtcClock(jobEvent.OccurredAtUtc, includeMilliseconds: true)</span>
                                                </div>
                                            </td>
                                            <td>@DashboardFormat.LogMessage(jobEvent)</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>
        </div>
    }
</div>

<style>
    .job-detail-page {
        display: flex;
        max-width: 1400px;
        margin: 0 auto;
        flex-direction: column;
        gap: var(--sd-page-margin);
    }

    .job-detail-toolbar,
    .job-detail-toolbar__primary,
    .job-detail-hero__main,
    .job-detail-title-row,
    .job-detail-actions,
    .job-detail-progress-line,
    .job-detail-log-header,
    .job-detail-log-header>div,
    .job-detail-log-actions,
    .job-detail-back-link,
    .job-detail-stream-status {
        display: flex;
        align-items: center;
    }

    .job-detail-toolbar {
        justify-content: space-between;
        gap: var(--sd-gutter);
    }

    .job-detail-toolbar__primary {
        gap: 16px;
        min-width: 0;
    }

    .job-detail-toolbar__title {
        color: var(--sd-primary);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 16px;
        text-transform: uppercase;
    }

    .job-detail-back-link {
        gap: 6px;
        color: var(--sd-on-surface-variant);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 16px;
        text-decoration: none;
        text-transform: uppercase;
    }

    .job-detail-back-link:hover {
        color: var(--sd-primary);
    }

    .job-detail-message,
    .job-detail-inline-alert {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        padding: 16px;
    }

    .job-detail-message .material-symbols-outlined,
    .job-detail-inline-alert .material-symbols-outlined {
        color: var(--sd-primary);
    }

    .job-detail-message p,
    .job-detail-inline-alert,
    .job-detail-muted,
    .job-detail-empty,
    .job-detail-empty-row {
        color: var(--sd-on-surface-variant);
    }

    .job-detail-message--error,
    .job-detail-inline-alert--error {
        border-color: var(--sd-error);
        background: var(--sd-error-container);
        color: var(--sd-on-error-container);
    }

    .job-detail-message--error .material-symbols-outlined,
    .job-detail-inline-alert--error .material-symbols-outlined {
        color: var(--sd-error);
    }

    .job-detail-inline-alert--warning {
        border-color: var(--sd-warning);
        background: var(--sd-warning-container);
        color: var(--sd-warning);
    }

    .job-detail-inline-alert--warning .material-symbols-outlined {
        color: var(--sd-warning);
    }

    .job-detail-inline-alert--success {
        border-color: var(--sd-success);
        background: var(--sd-success-container);
        color: var(--sd-success);
    }

    .job-detail-inline-alert--success .material-symbols-outlined {
        color: var(--sd-success);
    }

    .job-detail-not-found-canvas {
        display: flex;
        min-height: min(640px, calc(100vh - 160px));
        align-items: center;
        justify-content: center;
        padding: 48px 16px;
    }

    .job-detail-not-found-card {
        display: flex;
        width: 100%;
        max-width: 448px;
        align-items: center;
        flex-direction: column;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        padding: 32px;
        text-align: center;
    }

    .job-detail-not-found-card__icon {
        display: inline-flex;
        width: 64px;
        height: 64px;
        align-items: center;
        justify-content: center;
        margin-bottom: 24px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 999px;
        background: var(--sd-surface-variant);
        color: var(--sd-primary);
    }

    .job-detail-not-found-card__icon .material-symbols-outlined {
        font-size: 32px;
    }

    .job-detail-not-found-card h1 {
        color: var(--sd-on-surface);
        font-size: 24px;
        line-height: 32px;
    }

    .job-detail-not-found-card p {
        max-width: 360px;
        margin-top: 8px;
        color: var(--sd-on-surface-variant);
        font-size: 14px;
        line-height: 20px;
    }

    .job-detail-not-found-card__id {
        display: inline-block;
        max-width: 100%;
        overflow: hidden;
        margin-top: 8px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-high);
        color: var(--sd-primary);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 13px;
        line-height: 18px;
        padding: 2px 8px;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .job-detail-not-found-card__action {
        display: inline-flex;
        min-height: 36px;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-top: 32px;
        border: 1px solid var(--sd-primary);
        border-radius: 2px;
        background: var(--sd-primary);
        color: var(--sd-on-primary);
        padding: 8px 14px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-decoration: none;
        text-transform: uppercase;
    }

    .job-detail-not-found-card__action:hover {
        background: var(--sd-surface-lowest);
        color: var(--sd-primary);
    }

    .job-detail-not-found-card__action .material-symbols-outlined {
        font-size: 16px;
    }

    .job-detail-hero,
    .job-detail-panel {
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
    }

    .job-detail-hero {
        display: flex;
        flex-direction: column;
        gap: 16px;
        padding: 16px;
    }

    .job-detail-hero__main {
        justify-content: space-between;
        gap: 16px;
    }

    .job-detail-identity {
        min-width: 0;
    }

    .job-detail-title-row {
        min-width: 0;
        gap: 12px;
    }

    .job-detail-title-row h1 {
        overflow: hidden;
        color: var(--sd-primary);
        font-size: 24px;
        line-height: 32px;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .job-detail-identity p {
        margin-top: 4px;
        color: var(--sd-on-surface-variant);
        font-size: 12px;
        line-height: 16px;
    }

    .job-detail-handler,
    .job-detail-mono,
    .job-detail-metadata-item strong,
    .job-detail-chip,
    .job-detail-invocation-call,
    .job-detail-inline-duration,
    .job-detail-parameter pre,
    .job-detail-progress-percent,
    .job-detail-log-table,
    .job-detail-timeline__time span {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .job-detail-handler {
        display: inline-block;
        max-width: min(760px, 80vw);
        overflow: hidden;
        border-radius: 2px;
        background: var(--sd-surface-container);
        color: var(--sd-primary);
        padding: 1px 5px;
        text-decoration: none;
        text-overflow: ellipsis;
        vertical-align: bottom;
        white-space: nowrap;
    }

    .job-detail-filter-link:hover {
        color: var(--sd-primary);
        text-decoration: underline;
        text-decoration-color: var(--sd-primary);
        text-underline-offset: 2px;
    }

    .job-detail-actions {
        flex: 0 0 auto;
        gap: 12px;
    }

    .job-detail-page button.job-detail-button,
    .job-detail-page button.job-detail-icon-button {
        display: inline-flex;
        min-height: 34px;
        align-items: center;
        justify-content: center;
        gap: 7px;
        border-radius: 2px;
        padding: 7px 12px;
        font-size: 12px;
        font-weight: 700;
        line-height: 16px;
        transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
    }

    .job-detail-page button.job-detail-button--secondary,
    .job-detail-page button.job-detail-icon-button {
        border: 1px solid var(--sd-outline-variant);
        background: var(--sd-surface-lowest);
        color: var(--sd-on-surface);
    }

    .job-detail-page button.job-detail-button--danger {
        border: 1px solid var(--sd-error);
        background: var(--sd-error-container);
        color: var(--sd-on-error-container);
    }

    .job-detail-page button.job-detail-button--compact {
        min-height: 30px;
        padding: 5px 9px;
    }

    .job-detail-page button.job-detail-icon-button {
        width: 30px;
        min-height: 30px;
        padding: 0;
    }

    .job-detail-page button.job-detail-button:hover:not(:disabled),
    .job-detail-page button.job-detail-icon-button:hover:not(:disabled) {
        border-color: var(--sd-primary);
        color: var(--sd-primary);
    }

    .job-detail-page button.job-detail-button--danger:hover:not(:disabled) {
        border-color: var(--sd-error);
        color: var(--sd-error);
    }

    .job-detail-page button:disabled {
        cursor: default;
        opacity: 0.6;
    }

    .job-detail-actions .job-detail-cancel-action:disabled {
