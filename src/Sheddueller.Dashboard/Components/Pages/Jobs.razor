        font-size: 13px;
        line-height: 18px;
        text-decoration-color: var(--sd-outline-variant);
        text-underline-offset: 2px;
    }

    .jobs-id-link:hover {
        text-decoration-color: var(--sd-primary);
    }

    .jobs-handler {
        display: block;
        max-width: 240px;
        overflow: hidden;
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        text-overflow: ellipsis;
    }

    .jobs-state {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        padding: 2px 8px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
