    button.jobs-execute-button {
        display: inline-flex;
        width: 100%;
        height: 32px;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    button.jobs-execute-button .material-symbols-outlined {
