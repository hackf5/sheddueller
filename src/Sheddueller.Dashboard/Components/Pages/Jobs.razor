    .jobs-toolbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
    }

    .jobs-toolbar p {
        color: var(--sd-on-surface-variant);
        font-size: 12px;
        line-height: 16px;
    }

    .jobs-toolbar__actions {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .jobs-message,
    .jobs-inline-alert {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        padding: 16px;
    }

    .jobs-message .material-symbols-outlined,
    .jobs-inline-alert .material-symbols-outlined {
        color: var(--sd-primary);
    }

    .jobs-message--error,
    .jobs-inline-alert--error {
        border-color: var(--sd-error);
        background: var(--sd-error-container);
        color: var(--sd-on-error-container);
    }

    .jobs-message--error .material-symbols-outlined,
    .jobs-inline-alert--error .material-symbols-outlined {
        color: var(--sd-error);
    }

    .jobs-message p,
    .jobs-inline-alert {
        color: var(--sd-on-surface-variant);
    }

    .jobs-inline-alert--error {
        color: var(--sd-on-error-container);
    }

    .jobs-table-shell {
