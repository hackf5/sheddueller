@page "/jobs"
@inherits DashboardPageComponent
@inject IJobInspectionReader Reader
@inject DashboardLiveUpdateStream LiveUpdates
@inject NavigationManager Navigation

<div class="jobs-page">
    <header class="jobs-header">
        <div>
            <h1>Jobs</h1>
            <p>@HeaderText</p>
        </div>
    </header>

    <section class="jobs-filter-bar" aria-label="Job filters">
        <div class="jobs-status-filter" role="group" aria-label="Filter by status">
            <span class="jobs-filter-label">Status</span>
            @foreach (var state in Enum.GetValues<JobState>())
            {
                <label class="@StatusFilterClass(state)">
                    <input type="checkbox" checked="@_filters.IsStateSelected(state)" @onchange="eventArgs => SetStateFilterAsync(state, eventArgs)" />
                    <span>@state</span>
                </label>
            }
        </div>

        <div class="jobs-text-filters">
            <select class="sd-table-select jobs-sort-filter" aria-label="Sort jobs"
                    value="@_filters.Sort" @onchange="SetSortAsync">
                <option value="@JobInspectionSort.Operational">Operational Order</option>
                <option value="@JobInspectionSort.NewestFirst">Newest First</option>
            </select>
            <DashboardSearchBox Value="@_filters.HandlerContains" ValueChanged="SetHandlerContainsAsync"
                                Placeholder="Handler contains..." AriaLabel="Filter by handler substring" />
            <DashboardSearchBox Value="@_filters.TagContains" ValueChanged="SetTagContainsAsync"
                                Placeholder="Tag contains..." AriaLabel="Filter by tag substring" />
            <DashboardSearchBox Value="@_filters.ConcurrencyGroupContains" ValueChanged="SetConcurrencyGroupContainsAsync"
                                Placeholder="Group contains..." AriaLabel="Filter by concurrency group substring" />
            <button class="jobs-clear-button" type="button" @onclick="ClearAllAsync" disabled="@(!_filters.HasAppliedFilters)">
                Clear Filters
            </button>
        </div>
    </section>

    @if (_error is not null)
    {
        <section class="jobs-message jobs-message--error" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">error</span>
            <div>
                <h2>Jobs failed to load</h2>
                <p>@_error</p>
            </div>
        </section>
    }
    else if (_page is null)
    {
        <section class="jobs-message" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">progress_activity</span>
            <div>
                <h2>Loading jobs</h2>
                <p>Reading scheduler job records.</p>
            </div>
        </section>
    }
    else
    {
        @if (LiveRefresh.RefreshError is not null)
        {
            <DashboardInlineAlert CssClass="jobs-inline-alert jobs-inline-alert--error" Icon="warning">
                <span>Refresh failed: @LiveRefresh.RefreshError</span>
            </DashboardInlineAlert>
        }

        <div class="jobs-table-shell">
            <div class="jobs-table-wrap">
                <table class="jobs-table">
                    <colgroup>
                        <col class="jobs-table__col--job-id" />
                        <col class="jobs-table__col--timestamp" />
                        <col class="jobs-table__col--timestamp" />
                        <col class="jobs-table__col--state" />
                        <col class="jobs-table__col--queue" />
                        <col class="jobs-table__col--handler" />
                        <col class="jobs-table__col--tags" />
                        <col class="jobs-table__col--progress-unit" />
                        <col class="jobs-table__col--progress-unit" />
                        <col class="jobs-table__col--disposition" />
                        <col class="jobs-table__col--groups" />
                        <col class="jobs-table__col--priority" />
                        <col class="jobs-table__col--attempts" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Job ID</th>
                            <th>Enqueued</th>
                            <th>Terminal Time</th>
                            <th>State</th>
                            <th>Queue</th>
                            <th>Handler</th>
                            <th>Tags</th>
                            <th colspan="2">Progress</th>
                            <th>Disposition</th>
                            <th>Groups</th>
                            <th class="jobs-table__number">Pri</th>
                            <th class="jobs-table__number">Att</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_jobs.Count == 0)
                        {
                            <tr>
                                <td class="jobs-empty-row" colspan="13">@EmptyText</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var job in _jobs)
                            {
                                <tr @key="job.JobId">
                                    <td>
                                        <JobLink CssClass="jobs-id-link" JobId="job.JobId" />
                                    </td>
                                    <td>
                                        <TimestampBlock BaseClass="jobs-timestamp" Value="job.EnqueuedAtUtc"
                                                        AllowFutureRelative="false" />
                                    </td>
                                    <td>
                                        <TimestampBlock BaseClass="jobs-timestamp"
                                                        Value="DashboardFormat.TerminalTimestamp(job)"
                                                        AllowFutureRelative="false" />
                                    </td>
                                    <td>
                                        <StateBadge BaseClass="jobs-state" State="job.State" Href="@StateFilterHref(job.State)"
                                                    Title="@StateFilterTitle(job.State)" AriaLabel="@StateFilterTitle(job.State)" />
                                    </td>
                                    <td>
                                        <span class="@QueuePositionClass(job)" title="@QueuePositionTitle(job)">@QueuePositionText(job)</span>
                                    </td>
                                    <td>
                                        <a class="jobs-handler jobs-filter-link" href="@HandlerFilterHref(job)"
                                           title="@DashboardFormat.FullHandler(job)"
                                           aria-label="@HandlerFilterTitle(job)">@DashboardFormat.ShortHandler(job)</a>
                                    </td>
                                    <td>
                                        <TagChipList ClassPrefix="jobs-chip" Tags="job.Tags" HrefFactory="TagFilterHref"
                                                     LinkAriaLabelPrefix="Filter jobs by tag" MaxVisible="2" />
                                    </td>
                                    <td colspan="2">
                                        <ProgressIndicator BaseClass="jobs-progress" Progress="job.LatestProgress" />
                                    </td>
                                    <td>
                                        <span class="jobs-disposition @GetDispositionClass(job)"
                                              title="@DashboardFormat.Disposition(job)">@DashboardFormat.Disposition(job)</span>
                                    </td>
                                    <td>
                                        <ChipList ClassPrefix="jobs-chip" Values="job.ConcurrencyGroupKeys"
                                                  Title="@DashboardFormat.GroupKeysTitle(job.ConcurrencyGroupKeys)"
                                                  HrefFactory="GroupFilterHref"
                                                  LinkAriaLabelPrefix="Filter jobs by group" />
                                    </td>
                                    <td class="jobs-table__number">@job.Priority</td>
                                    <td class="jobs-table__number">@DashboardFormat.Attempts(job, compact: true)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <footer class="jobs-pagination">
                <span>@ResultRangeText</span>
                @if (_page.ContinuationToken is not null)
                {
                    <button class="jobs-load-more-button" type="button" @onclick="LoadMoreAsync" disabled="@(_isLoading || _isLoadingMore)">
                        @(_isLoadingMore ? "Loading Records" : "Load More Records")
                    </button>
                }
            </footer>
        </div>
    }
</div>

<style>
    .jobs-page {
        display: flex;
        height: calc(100vh - (var(--sd-page-margin) * 2));
        min-height: 0;
        flex-direction: column;
        gap: var(--sd-gutter);
    }

    .jobs-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .jobs-header p {
        margin-top: 4px;
        color: var(--sd-on-surface-variant);
        font-size: 12px;
        line-height: 16px;
    }

    .jobs-filter-bar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px 12px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: var(--sd-radius);
        background: var(--sd-surface-lowest);
        padding: 8px;
    }

    .jobs-status-filter,
    .jobs-text-filters {
        display: flex;
        min-width: 0;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
    }

    .jobs-text-filters {
        flex: 1 1 560px;
    }

    .jobs-filter-label {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .jobs-status-option {
        position: relative;
        display: inline-flex;
        cursor: pointer;
    }

    .jobs-status-option input {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        clip-path: inset(50%);
        white-space: nowrap;
    }

    .jobs-status-option span {
        display: inline-flex;
        min-height: 32px;
        align-items: center;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-container);
        color: var(--sd-on-surface-variant);
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
        transition: background-color 150ms ease, border-color 150ms ease, color 150ms ease;
    }

    .jobs-status-option input:checked+span {
        border-color: var(--sd-primary);
        background: var(--sd-secondary-container);
        color: var(--sd-on-secondary-container);
    }

    .jobs-status-option input:focus-visible+span {
        outline: 2px solid var(--sd-primary);
        outline-offset: 2px;
    }

    .jobs-filter-bar .sd-table-search {
        flex: 1 1 190px;
        width: auto;
        min-width: 180px;
    }

    .jobs-filter-bar .sd-table-select {
        flex: 0 0 166px;
        min-width: 150px;
    }

    button.jobs-clear-button,
    button.jobs-load-more-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        min-height: 32px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        color: var(--sd-on-surface);
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    button.jobs-load-more-button {
        min-width: 160px;
    }

    button.jobs-clear-button:hover,
    button.jobs-load-more-button:hover {
        color: var(--sd-primary);
    }

    .jobs-page button:disabled,
    .jobs-page input:disabled {
        cursor: progress;
        opacity: 0.65;
    }

    .jobs-message,
    .jobs-inline-alert {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        padding: 16px;
    }

    .jobs-message .material-symbols-outlined,
    .jobs-inline-alert .material-symbols-outlined {
        color: var(--sd-primary);
    }

    .jobs-message--error,
    .jobs-inline-alert--error {
        border-color: var(--sd-error);
        background: var(--sd-error-container);
        color: var(--sd-on-error-container);
    }

    .jobs-message--error .material-symbols-outlined,
    .jobs-inline-alert--error .material-symbols-outlined {
        color: var(--sd-error);
    }

    .jobs-message p,
    .jobs-inline-alert {
        color: var(--sd-on-surface-variant);
    }

    .jobs-inline-alert--error {
        color: var(--sd-on-error-container);
    }

    .jobs-table-shell {
        display: flex;
        flex: 1 1 auto;
        min-height: 0;
        min-width: 0;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
    }

    .jobs-table-wrap {
        flex: 1 1 auto;
        min-height: 0;
        overflow: auto;
    }

    .jobs-table {
        width: 100%;
        min-width: 1816px;
        border-collapse: collapse;
        table-layout: fixed;
        white-space: nowrap;
    }

    .jobs-table__col--job-id {
        width: 64px;
    }

    .jobs-table__col--state {
        width: 144px;
    }

    .jobs-table__col--queue {
        width: 96px;
    }

    .jobs-table__col--tags {
        width: 380px;
    }

    .jobs-table__col--disposition {
        width: 144px;
    }

    .jobs-table__col--priority {
        width: 64px;
    }

    .jobs-table__col--timestamp {
        width: 172px;
    }

    .jobs-table__col--attempts {
        width: 64px;
    }

    .jobs-table thead {
        position: sticky;
        top: 0;
        z-index: 1;
        background: var(--sd-surface-low);
    }

    .jobs-table th,
    .jobs-table td {
        border-bottom: 1px solid var(--sd-outline-variant);
        padding: 6px 8px;
        text-align: left;
        vertical-align: middle;
    }

    .jobs-table th {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .jobs-table td {
        height: 40px;
        color: var(--sd-on-surface);
        font-size: 12px;
        line-height: 16px;
    }

    .jobs-table tbody tr:hover {
        background: var(--sd-surface-low);
    }

    .jobs-table__number {
        text-align: right;
    }

    .jobs-id-link,
    .jobs-handler,
    .jobs-disposition,
    .jobs-chip,
    .jobs-progress-text,
    .jobs-timestamp__absolute {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .jobs-id-link {
        display: block;
        overflow: hidden;
        color: var(--sd-primary);
        font-size: 13px;
        line-height: 18px;
        text-overflow: ellipsis;
        text-decoration-color: var(--sd-outline-variant);
        text-underline-offset: 2px;
        white-space: nowrap;
    }

    .jobs-id-link:hover {
        text-decoration-color: var(--sd-primary);
    }

    .jobs-handler {
        display: block;
        width: 100%;
        overflow: hidden;
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        text-decoration: none;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    a.jobs-handler:hover {
        color: var(--sd-primary);
        text-decoration: underline;
        text-decoration-color: var(--sd-primary);
        text-underline-offset: 2px;
    }

    .jobs-chip-list {
        display: flex;
        width: 100%;
        min-width: 0;
        align-items: center;
        gap: 4px;
        overflow: visible;
    }

    .jobs-chip {
        display: inline-block;
        max-width: 180px;
        overflow: hidden;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-low);
        color: var(--sd-on-surface-variant);
        font-size: 10px;
        line-height: 14px;
        padding: 1px 6px;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    a.jobs-chip {
        text-decoration: none;
    }

    a.jobs-chip:hover,
    a.jobs-state:hover {
        border-color: var(--sd-primary);
        color: var(--sd-primary);
    }

    .jobs-chip-empty {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        line-height: 16px;
    }

    .jobs-state {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        padding: 2px 8px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-decoration: none;
        text-transform: uppercase;
    }

    .jobs-state>span {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: var(--sd-outline);
    }

    .jobs-state--queued {
        background: var(--sd-surface);
        color: var(--sd-on-surface-variant);
    }

    .jobs-state--claimed {
        border-color: var(--sd-secondary-container);
        background: var(--sd-secondary-container);
        color: var(--sd-on-secondary-container);
    }

    .jobs-state--claimed>span {
        background: var(--sd-primary);
    }

    .jobs-state--completed {
        background: var(--sd-surface-variant);
        color: var(--sd-on-surface);
    }

    .jobs-state--failed {
        border-color: var(--sd-error-container);
        background: var(--sd-error-container);
        color: var(--sd-on-error-container);
    }

    .jobs-state--failed>span {
        background: var(--sd-error);
    }

    .jobs-state--canceled {
        background: var(--sd-surface-high);
        color: var(--sd-outline);
    }

    .jobs-disposition {
        display: block;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .jobs-queue {
        display: inline-flex;
        min-width: 56px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        padding: 2px 6px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        font-size: 10px;
        font-weight: 700;
        line-height: 12px;
        text-transform: uppercase;
    }

    .jobs-queue--claimable {
        border-color: var(--sd-primary);
        color: var(--sd-primary);
    }

    .jobs-queue--claimed {
        border-color: var(--sd-secondary-container);
        background: var(--sd-secondary-container);
        color: var(--sd-on-secondary-container);
    }

    .jobs-queue--blocked,
    .jobs-queue--waiting,
    .jobs-queue--delayed {
        color: var(--sd-on-surface-variant);
    }

    .jobs-queue--empty {
        min-width: 0;
        border-color: transparent;
        color: var(--sd-on-surface-variant);
    }

    .jobs-disposition--error {
        color: var(--sd-error);
    }

    .jobs-disposition--muted {
        color: var(--sd-on-surface-variant);
    }

    .jobs-timestamp {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .jobs-timestamp__relative {
        color: var(--sd-on-surface);
    }

    .jobs-timestamp__absolute,
    .jobs-progress-text,
    .jobs-empty-row,
    .jobs-pagination {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        line-height: 16px;
    }

    .jobs-progress {
        display: flex;
        width: 100%;
        min-width: 0;
        flex-direction: column;
        gap: 3px;
    }

    .jobs-progress-text {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .jobs-progress__track {
        width: 100%;
        height: 6px;
        overflow: hidden;
        border-radius: 999px;
        background: var(--sd-surface-variant);
    }

    .jobs-progress__bar {
        height: 100%;
        border-radius: inherit;
        background: var(--sd-primary);
    }

    .jobs-empty-row {
        height: 96px;
        text-align: center;
    }

    .jobs-pagination {
        display: flex;
        min-height: 56px;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border-top: 1px solid var(--sd-outline-variant);
        background: var(--sd-surface-lowest);
        padding: 12px 16px;
    }

    @@media (max-width: 1100px) {
        .jobs-page {
            height: auto;
            min-height: 0;
        }
    }

    @@media (max-width: 720px) {
        .jobs-filter-bar,
        .jobs-status-filter,
        .jobs-text-filters,
        .jobs-filter-bar .sd-table-search,
        .jobs-filter-bar .sd-table-select,
        button.jobs-clear-button,
        .jobs-pagination {
            width: 100%;
        }

        .jobs-filter-bar,
        .jobs-status-filter,
        .jobs-text-filters,
        .jobs-pagination {
            align-items: stretch;
            flex-direction: column;
        }

        .jobs-status-option span {
            justify-content: center;
        }
    }
</style>

@code {
    private static readonly TimeSpan FilterDebounce = TimeSpan.FromMilliseconds(300);
    private const int DefaultPageSize = 25;

    private readonly DashboardJobFilters _filters = new();
    private readonly List<JobInspectionSummary> _jobs = [];
    private JobInspectionPage? _page;
    private JobInspectionQuery _lastQuery = new(PageSize: DefaultPageSize);
    private CancellationTokenSource? _filterDebounceCts;
    private string? _error;
    private string? _pendingFilterNavigationUri;
    private int _queryVersion;
    private bool _isLoading;
    private bool _isLoadingMore;

    private string HeaderText
      => this._page is null ? "Reading scheduler job records." : this.ResultRangeText;

    private string EmptyText
      => this._filters.HasAppliedFilters
        ? "No jobs matched the current filters."
        : "No jobs are available.";

    private string ResultRangeText
    {
        get
        {
            var loadedCount = this._jobs.Count;
            var totalCount = this._page?.TotalCount ?? loadedCount;
            var filterText = this._filters.HasAppliedFilters ? " matching filters" : string.Empty;
            var moreText = this._page?.ContinuationToken is null ? string.Empty : " with more available";

            return loadedCount == 0
              ? string.Create(CultureInfo.InvariantCulture, $"Showing 0 of {DashboardFormat.Count(totalCount)} jobs{filterText}")
              : string.Create(CultureInfo.InvariantCulture, $"Showing 1-{DashboardFormat.Count(loadedCount)} of {DashboardFormat.Count(totalCount)} jobs{filterText}{moreText}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += this.OnLocationChanged;
        _ = this._filters.ReplaceWith(DashboardJobFilterQuery.ParseUri(Navigation.Uri));
        this.InitializeLiveRefresh(
          this.RefreshCurrentQueryAsync,
          showRefreshing: true,
          lastUpdatedUtc: nowUtc => this.LiveRefresh.LastUpdatedUtc ?? (this._page is null ? null : nowUtc));
        LiveUpdates.JobEventPublished += this.OnJobEventPublishedAsync;
        await this.LoadAsync();
    }

    private protected override ValueTask DisposePageAsync()
    {
        Navigation.LocationChanged -= this.OnLocationChanged;
        LiveUpdates.JobEventPublished -= this.OnJobEventPublishedAsync;
        this.CancelPendingFilterLoad();
        return ValueTask.CompletedTask;
    }

    private async Task SetStateFilterAsync(
        JobState state,
        ChangeEventArgs eventArgs)
    {
        if (!this._filters.SetStateSelected(state, eventArgs.Value is bool selected && selected))
        {
            return;
        }

        this.CancelPendingFilterLoad();
        this.NavigateToCurrentFilters();
        await this.LoadAsync();
    }

    private Task SetHandlerContainsAsync(string value)
      => this.SetTextFilterAsync(value, this._filters.SetHandlerContains);

    private Task SetTagContainsAsync(string value)
      => this.SetTextFilterAsync(value, this._filters.SetTagContains);

    private Task SetConcurrencyGroupContainsAsync(string value)
      => this.SetTextFilterAsync(value, this._filters.SetConcurrencyGroupContains);

    private async Task SetSortAsync(ChangeEventArgs eventArgs)
    {
        if (eventArgs.Value is not string value
            || !Enum.TryParse<JobInspectionSort>(value, ignoreCase: true, out var sort)
            || !Enum.IsDefined(sort)
            || !this._filters.SetSort(sort))
        {
            return;
        }

        this.CancelPendingFilterLoad();
        this.NavigateToCurrentFilters();
        await this.LoadAsync();
    }

    private Task SetTextFilterAsync(
        string value,
        Func<string, bool> setFilter)
    {
        if (setFilter(value))
        {
            this.ScheduleDebouncedLoad();
        }

        return Task.CompletedTask;
    }

    private async Task ClearAllAsync()
    {
        if (!this._filters.HasAppliedFilters)
        {
            return;
        }

        this.CancelPendingFilterLoad();
        this._filters.Clear();
        this.NavigateToCurrentFilters();
        await this.LoadAsync();
    }

    private async Task LoadAsync()
    {
        var query = this.CreateQuery(DefaultPageSize, continuationToken: null);
        var queryVersion = ++this._queryVersion;
        this._lastQuery = query;
        this._error = null;
        this.LiveRefresh.ClearError();
        this._isLoading = true;

        try
        {
            var page = await Reader.SearchJobsAsync(query);
            if (queryVersion != this._queryVersion)
            {
                return;
            }

            this.ReplaceJobs(page);
            this.LiveRefresh.MarkUpdated();
        }
        catch (Exception exception)
        {
            if (queryVersion == this._queryVersion)
            {
                this._error = exception.Message;
            }
        }
        finally
        {
            if (queryVersion == this._queryVersion)
            {
                this._isLoading = false;
                this.NotifyShellRefreshChanged();
            }
        }
    }

    private async Task LoadMoreAsync()
    {
        if (this._page?.ContinuationToken is null || this._isLoading || this._isLoadingMore)
        {
            return;
        }

        var queryVersion = this._queryVersion;
        this._error = null;
        this._isLoadingMore = true;

        try
        {
            var page = await Reader.SearchJobsAsync(this._lastQuery with
            {
                PageSize = DefaultPageSize,
                ContinuationToken = this._page.ContinuationToken,
            });

            if (queryVersion != this._queryVersion)
            {
                return;
            }

            this._jobs.AddRange(page.Jobs);
            this._page = page;
            this.LiveRefresh.MarkUpdated();
        }
        catch (Exception exception)
        {
            if (queryVersion == this._queryVersion)
            {
                this._error = exception.Message;
            }
        }
        finally
        {
            if (queryVersion == this._queryVersion)
            {
                this._isLoadingMore = false;
                this.NotifyShellRefreshChanged();
            }
        }
    }

    private async ValueTask OnJobEventPublishedAsync(
        JobEvent jobEvent,
        CancellationToken cancellationToken)
    {
        _ = cancellationToken;

        await this.ApplyPageStateAsync(() => this.LiveRefresh.MarkLiveActivity(jobEvent.OccurredAtUtc));
        this.LiveRefresh.QueueRefresh();
    }

    private async Task RefreshCurrentQueryAsync(CancellationToken cancellationToken)
    {
        var queryVersion = this._queryVersion;
        var visiblePageSize = Math.Max(DefaultPageSize, this._jobs.Count);
        var page = await Reader.SearchJobsAsync(this._lastQuery with
        {
            PageSize = visiblePageSize,
            ContinuationToken = null,
        }, cancellationToken);

        if (queryVersion != this._queryVersion)
        {
            return;
        }

        await this.ApplyPageStateAsync(() => this.ReplaceJobs(page));
    }

    private void ScheduleDebouncedLoad()
    {
        var previous = this._filterDebounceCts;
        previous?.Cancel();

        var next = new CancellationTokenSource();
        this._filterDebounceCts = next;
        _ = this.RunDebouncedLoadAsync(next);
    }

    private async Task RunDebouncedLoadAsync(CancellationTokenSource cancellationTokenSource)
    {
        try
        {
            await Task.Delay(FilterDebounce, cancellationTokenSource.Token);
            await this.InvokeAsync(async () =>
            {
                this.NavigateToCurrentFilters();
                await this.LoadAsync();
            });
        }
        catch (OperationCanceledException) when (cancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(this._filterDebounceCts, cancellationTokenSource))
            {
                this._filterDebounceCts = null;
            }

            cancellationTokenSource.Dispose();
        }
    }

    private void CancelPendingFilterLoad()
    {
        var cancellationTokenSource = this._filterDebounceCts;
        this._filterDebounceCts = null;
        cancellationTokenSource?.Cancel();
    }

    private void OnLocationChanged(
        object? sender,
        LocationChangedEventArgs eventArgs)
    {
        _ = sender;

        if (!this.IsJobsListLocation(eventArgs.Location))
        {
            return;
        }

        if (string.Equals(NormalizeAbsoluteUri(eventArgs.Location), this._pendingFilterNavigationUri, StringComparison.Ordinal))
        {
            this._pendingFilterNavigationUri = null;
            return;
        }

        this._pendingFilterNavigationUri = null;
        _ = this.ApplyFilterLocationAsync(eventArgs.Location);
    }

    private async Task ApplyFilterLocationAsync(string location)
    {
        var nextFilters = DashboardJobFilterQuery.ParseUri(location);

        await this.InvokeAsync(async () =>
        {
            if (!this._filters.ReplaceWith(nextFilters))
            {
                return;
            }

            this.CancelPendingFilterLoad();
            await this.LoadAsync();
            this.StateHasChanged();
        });
    }

    private void NavigateToCurrentFilters()
    {
        var href = DashboardJobFilterQuery.ToHref(this._filters);
        if (string.Equals(Navigation.ToBaseRelativePath(Navigation.Uri), href, StringComparison.Ordinal))
        {
            return;
        }

        this._pendingFilterNavigationUri = Navigation.ToAbsoluteUri(href).AbsoluteUri;
        Navigation.NavigateTo(href, replace: true);
    }

    private bool IsJobsListLocation(string location)
    {
        var relativePath = Navigation.ToBaseRelativePath(location);
        var queryIndex = relativePath.IndexOf('?', StringComparison.Ordinal);
        var path = queryIndex < 0 ? relativePath : relativePath[..queryIndex];
        return string.Equals(path.TrimEnd('/'), "jobs", StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeAbsoluteUri(string uri)
      => new Uri(uri, UriKind.Absolute).AbsoluteUri;

    private JobInspectionQuery CreateQuery(
        int pageSize,
        string? continuationToken)
      => this._filters.ToQuery(pageSize, continuationToken);

    private void ReplaceJobs(JobInspectionPage page)
    {
        this._jobs.Clear();
        this._jobs.AddRange(page.Jobs);
        this._page = page;
    }

    private static string StatusFilterClass(JobState state)
      => string.Concat("jobs-status-option jobs-status-option--", DashboardFormat.StateCssModifier(state));

    private static string QueuePositionText(JobInspectionSummary job)
      => job.QueuePosition switch
      {
          { Kind: JobQueuePositionKind.Claimable, Position: { } position } => string.Create(CultureInfo.InvariantCulture, $"#{position}"),
          { Kind: JobQueuePositionKind.Claimable } => "Ready",
          { Kind: JobQueuePositionKind.Claimed } => "Running",
          { Kind: JobQueuePositionKind.BlockedByConcurrency } => "Blocked",
          { Kind: JobQueuePositionKind.RetryWaiting } => "Retry",
          { Kind: JobQueuePositionKind.Delayed } => "Delayed",
          _ => "-",
      };

    private static string QueuePositionTitle(JobInspectionSummary job)
      => job.QueuePosition?.Reason ?? QueuePositionText(job);

    private static string QueuePositionClass(JobInspectionSummary job)
      => string.Concat("jobs-queue jobs-queue--", job.QueuePosition?.Kind switch
      {
          JobQueuePositionKind.Claimable => "claimable",
          JobQueuePositionKind.Claimed => "claimed",
          JobQueuePositionKind.BlockedByConcurrency => "blocked",
          JobQueuePositionKind.RetryWaiting => "waiting",
          JobQueuePositionKind.Delayed => "delayed",
          _ => "empty",
      });

    private static string GetDispositionClass(JobInspectionSummary job)
      => job.State == JobState.Failed ? "jobs-disposition--error" : "jobs-disposition--muted";

    private string StateFilterHref(JobState state)
      => DashboardJobFilterQuery.WithStateHref(this._filters, state);

    private static string StateFilterTitle(JobState state)
      => string.Concat("Filter jobs by state ", state);

    private string HandlerFilterHref(JobInspectionSummary job)
      => DashboardJobFilterQuery.WithHandlerHref(this._filters, DashboardFormat.ShortHandler(job));

    private static string HandlerFilterTitle(JobInspectionSummary job)
      => string.Concat("Filter jobs by handler ", DashboardFormat.ShortHandler(job));

    private string TagFilterHref(string tag)
      => DashboardJobFilterQuery.WithTagHref(this._filters, tag);

    private string GroupFilterHref(string group)
      => DashboardJobFilterQuery.WithGroupHref(this._filters, group);
}
