    .jobs-time-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 4px;
        border-top: 1px solid var(--sd-outline-variant);
        padding-top: 12px;
    }

    .jobs-time-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 8px;
    }

    button.jobs-clear-button,
    button.jobs-toolbar-button,
    button.jobs-load-more-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        min-height: 32px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        color: var(--sd-on-surface);
        padding: 6px 10px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    button.jobs-clear-button {
        min-height: auto;
        border: 0;
        background: transparent;
        color: var(--sd-on-surface-variant);
