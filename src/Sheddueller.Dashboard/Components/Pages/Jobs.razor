    }

    .jobs-timestamp__absolute,
    .jobs-progress-text,
    .jobs-empty-row,
    .jobs-pagination {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        line-height: 16px;
    }

    .jobs-progress {
        display: flex;
        min-width: 104px;
        flex-direction: column;
        gap: 3px;
    }

    .jobs-progress__track {
        width: 100%;
        height: 6px;
        overflow: hidden;
        border-radius: 999px;
        background: var(--sd-surface-variant);
    }

    .jobs-progress__bar {
        height: 100%;
        border-radius: inherit;
        background: var(--sd-primary);
    }

    .jobs-empty-row {
        height: 96px;
        text-align: center;
    }

    .jobs-pagination {
        display: flex;
        min-height: 56px;
        align-items: center;
        justify-content: center;
        border-top: 1px solid var(--sd-outline-variant);
        background: var(--sd-surface-lowest);
        padding: 12px 16px;
    }

    @@media (max-width: 1100px) {
        .jobs-page {
            grid-template-columns: 1fr;
        }

        .jobs-query-form {
            max-height: none;
        }
    }

    @@media (max-width: 720px) {
        .jobs-toolbar,
        .jobs-toolbar__actions,
        .jobs-time-grid {
            align-items: stretch;
            flex-direction: column;
        }

        .jobs-toolbar__actions {
            gap: 8px;
        }

        .jobs-time-grid {
            display: flex;
        }
    }
</style>

@code {
    private const int DefaultPageSize = 25;
    private static readonly TimeSpan LiveRefreshThrottle = TimeSpan.FromSeconds(1);

    private readonly object _liveRefreshGate = new();
    private readonly List<DashboardJobSummary> _jobs = [];
    private string _jobIdText = string.Empty;
    private string _stateText = string.Empty;
    private string _serviceType = string.Empty;
    private string _methodName = string.Empty;
    private string _tagText = string.Empty;
    private string _sourceScheduleKey = string.Empty;
    private string _enqueuedFromText = string.Empty;
    private string _enqueuedToText = string.Empty;
    private DashboardJobPage? _page;
    private DashboardJobQuery _lastQuery = new(PageSize: DefaultPageSize);
    private string? _error;
    private string? _liveRefreshError;
    private DateTimeOffset? _lastUpdatedUtc;
    private bool _autoRefreshEnabled = true;
    private bool _disposed;
    private bool _isSearching;
    private bool _isRefreshing;
    private bool _isLoadingMore;
    private bool _refreshRequested;
    private bool _refreshLoopRunning;

    protected override async Task OnInitializedAsync()
    {
        LiveUpdates.JobEventPublished += this.OnJobEventPublishedAsync;
        await this.SearchAsync().ConfigureAwait(false);
    }

    public void Dispose()
    {
        LiveUpdates.JobEventPublished -= this.OnJobEventPublishedAsync;

        lock (this._liveRefreshGate)
        {
            this._disposed = true;
        }
    }

    private async Task SearchAsync()
    {
        this._error = null;
        this._liveRefreshError = null;
        this._isSearching = true;

        try
        {
            var query = this.CreateQuery(pageSize: DefaultPageSize, continuationToken: null);
            var page = await Reader.SearchJobsAsync(query).ConfigureAwait(false);
            this._lastQuery = query;
            this.ReplaceJobs(page);
        }
        catch (Exception exception)
        {
            this._error = exception.Message;
        }
        finally
        {
            this._isSearching = false;
        }
    }

    private async Task ClearAllAsync()
    {
        this._jobIdText = string.Empty;
        this._stateText = string.Empty;
        this._serviceType = string.Empty;
        this._methodName = string.Empty;
        this._tagText = string.Empty;
        this._sourceScheduleKey = string.Empty;
        this._enqueuedFromText = string.Empty;
        this._enqueuedToText = string.Empty;

        await this.SearchAsync().ConfigureAwait(false);
    }

    private async Task LoadMoreAsync()
    {
        if (this._page?.ContinuationToken is null || this._isLoadingMore)
        {
            return;
        }

        this._error = null;
        this._isLoadingMore = true;

        try
        {
            var page = await Reader.SearchJobsAsync(this._lastQuery with
            {
                PageSize = DefaultPageSize,
                ContinuationToken = this._page.ContinuationToken,
            }).ConfigureAwait(false);

            this._jobs.AddRange(page.Jobs);
            this._page = page;
            this._lastUpdatedUtc = DateTimeOffset.UtcNow;
        }
        catch (Exception exception)
        {
            this._error = exception.Message;
        }
        finally
        {
            this._isLoadingMore = false;
        }
    }

    private async Task ToggleAutoRefreshAsync()
    {
        this._autoRefreshEnabled = !this._autoRefreshEnabled;
        this._liveRefreshError = null;

        if (this._autoRefreshEnabled)
        {
            await this.RefreshCurrentQueryAsync().ConfigureAwait(false);
        }
        else
        {
            lock (this._liveRefreshGate)
            {
                this._refreshRequested = false;
            }
        }
    }

    private void SetEnqueuedFromText(ChangeEventArgs eventArgs)
      => this._enqueuedFromText = eventArgs.Value?.ToString() ?? string.Empty;

    private void SetEnqueuedToText(ChangeEventArgs eventArgs)
      => this._enqueuedToText = eventArgs.Value?.ToString() ?? string.Empty;

    private ValueTask OnJobEventPublishedAsync(
        DashboardJobEvent jobEvent,
        CancellationToken cancellationToken)
    {
        _ = jobEvent;
        _ = cancellationToken;

        if (this._autoRefreshEnabled)
        {
            this.QueueLiveRefresh();
        }

        return ValueTask.CompletedTask;
    }

    private void QueueLiveRefresh()
    {
        var startLoop = false;

        lock (this._liveRefreshGate)
        {
            if (this._disposed || !this._autoRefreshEnabled)
            {
                return;
            }

            this._refreshRequested = true;
            if (!this._refreshLoopRunning)
            {
                this._refreshLoopRunning = true;
                startLoop = true;
            }
        }

        if (startLoop)
        {
            _ = this.RunLiveRefreshLoopAsync();
        }
    }

    private async Task RunLiveRefreshLoopAsync()
    {
        var completedCleanly = false;

        try
        {
            while (true)
            {
                await Task.Delay(LiveRefreshThrottle).ConfigureAwait(false);

                lock (this._liveRefreshGate)
                {
                    if (this._disposed || !this._autoRefreshEnabled)
                    {
                        this._refreshLoopRunning = false;
                        completedCleanly = true;
                        return;
                    }

                    if (!this._refreshRequested)
                    {
                        this._refreshLoopRunning = false;
                        completedCleanly = true;
                        return;
                    }

                    this._refreshRequested = false;
                }

                await this.RefreshCurrentQueryAsync().ConfigureAwait(false);
            }
        }
        finally
        {
            lock (this._liveRefreshGate)
            {
                if (!completedCleanly && !this._disposed)
                {
                    this._refreshLoopRunning = false;
                }
            }
        }
    }

    private async Task RefreshCurrentQueryAsync()
    {
        await this.InvokeIfNotDisposedAsync(() =>
        {
            this._isRefreshing = true;
            this._liveRefreshError = null;
            this.StateHasChanged();
        }).ConfigureAwait(false);

        try
        {
            var visiblePageSize = Math.Max(DefaultPageSize, this._jobs.Count);
            var page = await Reader.SearchJobsAsync(this._lastQuery with
            {
                PageSize = visiblePageSize,
                ContinuationToken = null,
            }).ConfigureAwait(false);

            await this.InvokeIfNotDisposedAsync(() =>
            {
                this.ReplaceJobs(page);
                this._isRefreshing = false;
                this.StateHasChanged();
            }).ConfigureAwait(false);
        }
        catch (Exception exception)
        {
            await this.InvokeIfNotDisposedAsync(() =>
            {
                this._liveRefreshError = exception.Message;
                this._isRefreshing = false;
                this.StateHasChanged();
            }).ConfigureAwait(false);
        }
    }

    private async Task InvokeIfNotDisposedAsync(Action action)
    {
        if (this.IsDisposed())
        {
            return;
        }

        await this.InvokeAsync(() =>
        {
            if (!this.IsDisposed())
            {
                action();
            }
        }).ConfigureAwait(false);
    }

    private bool IsDisposed()
    {
        lock (this._liveRefreshGate)
        {
            return this._disposed;
        }
    }

    private void ReplaceJobs(DashboardJobPage page)
    {
        this._jobs.Clear();
        this._jobs.AddRange(page.Jobs);
        this._page = page;
        this._lastUpdatedUtc = DateTimeOffset.UtcNow;
    }

    private DashboardJobQuery CreateQuery(
        int pageSize,
        string? continuationToken)
    {
        var jobId = ParseJobId(this._jobIdText);
        var state = string.IsNullOrWhiteSpace(this._stateText) ? (JobState?)null : Enum.Parse<JobState>(this._stateText);
        var tag = ParseTag(this._tagText);
        var enqueuedFromUtc = ParseUtcDateTimeLocal(this._enqueuedFromText, "Enqueued from");
        var enqueuedToUtc = ParseUtcDateTimeLocal(this._enqueuedToText, "Enqueued to");

        if (enqueuedFromUtc is { } from && enqueuedToUtc is { } to && from > to)
        {
            throw new InvalidOperationException("Enqueued from must be earlier than enqueued to.");
        }

        return new DashboardJobQuery(
          jobId,
          state,
          NormalizeFilter(this._serviceType),
          NormalizeFilter(this._methodName),
          tag,
          NormalizeFilter(this._sourceScheduleKey),
          enqueuedFromUtc,
          enqueuedToUtc,
          PageSize: pageSize,
          ContinuationToken: continuationToken);
    }

    private static Guid? ParseJobId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (!Guid.TryParse(value.Trim(), out var jobId))
        {
            throw new InvalidOperationException("Job ID must be a valid GUID.");
        }

        return jobId;
    }

    private static JobTag? ParseTag(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var trimmed = value.Trim();
        var separatorIndex = trimmed.IndexOf(':', StringComparison.Ordinal);
        if (separatorIndex <= 0 || separatorIndex == trimmed.Length - 1)
        {
            throw new InvalidOperationException("Tags must use name:value syntax.");
        }

        var name = trimmed[..separatorIndex].Trim();
        var tagValue = trimmed[(separatorIndex + 1)..].Trim();
        if (name.Length == 0 || tagValue.Length == 0)
        {
            throw new InvalidOperationException("Tags must include both a name and value.");
        }

        return new JobTag(name, tagValue);
    }

    private static DateTimeOffset? ParseUtcDateTimeLocal(
        string value,
        string fieldName)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        if (!DateTime.TryParse(
            value.Trim(),
            CultureInfo.InvariantCulture,
            DateTimeStyles.AllowWhiteSpaces,
            out var parsed))
        {
            throw new InvalidOperationException(string.Create(CultureInfo.InvariantCulture, $"{fieldName} must be a valid UTC date and time."));
        }

        return new DateTimeOffset(DateTime.SpecifyKind(parsed, DateTimeKind.Utc));
    }

    private static string? NormalizeFilter(string value)
      => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private string FormatResultRange()
    {
        var loadedCount = this._jobs.Count;
        if (loadedCount == 0)
        {
            return string.Create(CultureInfo.InvariantCulture, $"Showing 0 of {FormatCount(this._page?.TotalCount ?? 0)} jobs");
        }

        return string.Create(CultureInfo.InvariantCulture, $"Showing 1-{FormatCount(loadedCount)} of {FormatCount(this._page?.TotalCount ?? loadedCount)} jobs");
    }

    private string GetLiveStatusClass()
    {
        if (this._liveRefreshError is not null)
        {
            return "sd-live-status--error";
        }

        return this._isRefreshing ? "sd-live-status--refreshing" : string.Empty;
    }

    private string GetLiveStatusText(DateTimeOffset nowUtc)
    {
        if (this._isRefreshing)
        {
            return "Refreshing...";
        }

        if (this._liveRefreshError is not null)
        {
            return "Refresh failed";
        }

        return this._lastUpdatedUtc is null
          ? "Waiting for data"
          : string.Concat("Updated ", FormatRelative(this._lastUpdatedUtc, nowUtc));
    }

    private static string CreateJobHref(DashboardJobSummary job)
      => string.Create(CultureInfo.InvariantCulture, $"jobs/{job.JobId:D}");

    private static string FormatJobId(Guid jobId)
      => jobId.ToString("D");

    private static string FormatCount(long count)
      => count.ToString("N0", CultureInfo.InvariantCulture);

    private static string FormatFullHandler(DashboardJobSummary job)
      => string.Concat(job.ServiceType, ".", job.MethodName);

    private static string FormatAttempts(DashboardJobSummary job)
      => string.Create(CultureInfo.InvariantCulture, $"{job.AttemptCount}/{job.MaxAttempts}");

    private static string FormatDisposition(DashboardJobSummary job)
      => job.State switch
      {
          JobState.Failed => FirstNonEmpty(job.LatestProgress?.Message, job.QueuePosition?.Reason, "failed"),
          JobState.Completed => "completed",
          JobState.Canceled => "canceled",
          _ => FormatQueueKind(job.QueuePosition?.Kind, job.State),
      };

    private static string FormatQueueKind(
        DashboardQueuePositionKind? kind,
        JobState state)
      => kind switch
      {
          DashboardQueuePositionKind.Claimable => "claimable",
          DashboardQueuePositionKind.Delayed => "delayed",
          DashboardQueuePositionKind.RetryWaiting => "retry_waiting",
          DashboardQueuePositionKind.BlockedByConcurrency => "blocked_by_concurrency",
          DashboardQueuePositionKind.Claimed => "running_active",
          DashboardQueuePositionKind.Terminal => "terminal",
          DashboardQueuePositionKind.Canceled => "canceled",
          DashboardQueuePositionKind.NotFound => "not_found",
          _ => state.ToString().ToLowerInvariant(),
      };

    private static string FirstNonEmpty(params string?[] values)
      => values.FirstOrDefault(static value => !string.IsNullOrWhiteSpace(value)) ?? string.Empty;

    private static DateTimeOffset? GetTerminalTimestamp(DashboardJobSummary job)
      => job.FailedAtUtc ?? job.CompletedAtUtc ?? job.CanceledAtUtc;

    private static string GetStateBadgeClass(JobState state)
      => state switch
      {
          JobState.Queued => "jobs-state--queued",
          JobState.Claimed => "jobs-state--claimed",
          JobState.Completed => "jobs-state--completed",
          JobState.Failed => "jobs-state--failed",
          JobState.Canceled => "jobs-state--canceled",
          _ => "jobs-state--queued",
      };

    private static string GetDispositionClass(DashboardJobSummary job)
      => job.State == JobState.Failed ? "jobs-disposition--error" : "jobs-disposition--muted";

    private static RenderFragment RenderTimestampBlock(
        DateTimeOffset? value,
        DateTimeOffset nowUtc)
      => builder =>
      {
          builder.OpenElement(0, "div");
          builder.AddAttribute(1, "class", "jobs-timestamp");

          builder.OpenElement(2, "span");
          builder.AddAttribute(3, "class", "jobs-timestamp__relative");
          builder.AddContent(4, FormatRelative(value, nowUtc));
          builder.CloseElement();

          builder.OpenElement(5, "span");
          builder.AddAttribute(6, "class", "jobs-timestamp__absolute");
          builder.AddContent(7, FormatUtc(value));
          builder.CloseElement();

          builder.CloseElement();
      };

    private static RenderFragment RenderProgress(DashboardProgressSnapshot? progress)
      => builder =>
      {
          if (progress?.Percent is not { } percent)
          {
              builder.OpenElement(0, "span");
              builder.AddAttribute(1, "class", "jobs-progress-text");
              builder.AddContent(2, progress?.Message ?? "N/A");
              builder.CloseElement();
              return;
          }

          var clampedPercent = Math.Clamp(percent, 0, 100);

          builder.OpenElement(3, "div");
          builder.AddAttribute(4, "class", "jobs-progress");

          builder.OpenElement(5, "div");
          builder.AddAttribute(6, "class", "jobs-progress__track");

          builder.OpenElement(7, "div");
          builder.AddAttribute(8, "class", "jobs-progress__bar");
          builder.AddAttribute(9, "style", string.Create(CultureInfo.InvariantCulture, $"width: {clampedPercent:0.##}%"));
          builder.CloseElement();

          builder.CloseElement();

          builder.OpenElement(10, "span");
          builder.AddAttribute(11, "class", "jobs-progress-text");
          builder.AddContent(12, FormatProgress(progress));
          builder.CloseElement();

          builder.CloseElement();
      };

    private static string FormatProgress(DashboardProgressSnapshot progress)
      => progress.Percent is null
        ? progress.Message ?? "Progress reported"
        : string.Create(CultureInfo.InvariantCulture, $"{progress.Percent:0.#}% {progress.Message}").Trim();

    private static string FormatRelative(
        DateTimeOffset? value,
        DateTimeOffset nowUtc)
    {
        if (value is null)
        {
            return "-";
        }

        var targetUtc = value.Value.ToUniversalTime();
        var delta = targetUtc - nowUtc.ToUniversalTime();
        var future = delta > TimeSpan.Zero;
        var duration = future ? delta : -delta;
        var text = FormatDuration(duration);

        return future
          ? string.Concat("in ", text)
          : string.Concat(text, " ago");
    }

    private static string FormatDuration(TimeSpan duration)
    {
        if (duration < TimeSpan.FromMinutes(1))
        {
            return "<1m";
        }

        if (duration < TimeSpan.FromHours(1))
        {
            return string.Create(CultureInfo.InvariantCulture, $"{Math.Floor(duration.TotalMinutes):0}m");
        }

        if (duration < TimeSpan.FromDays(1))
        {
            return string.Create(CultureInfo.InvariantCulture, $"{Math.Floor(duration.TotalHours):0}h");
        }

        return string.Create(CultureInfo.InvariantCulture, $"{Math.Floor(duration.TotalDays):0}d");
    }

    private static string FormatUtc(DateTimeOffset? value)
      => value?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm:ss 'UTC'", CultureInfo.InvariantCulture) ?? string.Empty;
}
