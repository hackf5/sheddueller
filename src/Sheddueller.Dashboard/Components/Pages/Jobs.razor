    }

    .jobs-page .jobs-toolbar__actions button.jobs-toolbar-button {
        color: var(--sd-on-surface-variant);
        white-space: nowrap;
        border-color: var(--sd-outline-variant);
        background: var(--sd-surface-lowest);
    }

    .jobs-page .jobs-toolbar__actions button.jobs-toolbar-button--active {
        border-color: var(--sd-primary);
