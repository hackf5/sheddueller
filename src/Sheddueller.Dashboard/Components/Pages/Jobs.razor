@page "/jobs"
@implements IDisposable
@inject IDashboardJobReader Reader
@inject DashboardLiveUpdateStream LiveUpdates

<div class="jobs-page">
    <aside class="jobs-query-panel">
        <form class="jobs-query-form" @onsubmit="SearchAsync" @onsubmit:preventDefault="true">
            <div class="jobs-query-panel__header">
                <h2>Query Parameters</h2>
                <button class="jobs-clear-button" type="button" @onclick="ClearAllAsync" disabled="@_isSearching">Clear All</button>
            </div>

            <div class="jobs-query-panel__body">
                <label class="jobs-field">
                    <span>Job ID</span>
                    <input class="jobs-input jobs-input--mono" @bind="_jobIdText" @bind:event="oninput" placeholder="8c32d457-9e7a-42bb-8947-0c8fa54743be" />
                </label>

                <label class="jobs-field">
                    <span>State</span>
                    <select class="jobs-input" @bind="_stateText">
                        <option value="">Any State</option>
                        @foreach (var state in Enum.GetValues<JobState>())
                        {
                            <option value="@state">@state</option>
                        }
                    </select>
                </label>

                <label class="jobs-field">
                    <span>Handler Service</span>
                    <input class="jobs-input jobs-input--mono" @bind="_serviceType" @bind:event="oninput" placeholder="Sheddueller.Worker" />
                </label>

                <label class="jobs-field">
                    <span>Method</span>
                    <input class="jobs-input jobs-input--mono" @bind="_methodName" @bind:event="oninput" placeholder="RunAsync" />
                </label>

                <label class="jobs-field">
                    <span>Tags (Exact Match)</span>
                    <input class="jobs-input jobs-input--mono" @bind="_tagText" @bind:event="oninput" placeholder="tenant:acme" />
                </label>

                <label class="jobs-field">
                    <span>Schedule Key</span>
                    <input class="jobs-input jobs-input--mono" @bind="_sourceScheduleKey" @bind:event="oninput" placeholder="daily_rollup" />
                </label>

                <div class="jobs-time-group">
                    <span class="jobs-time-group__label">Time Range (Enqueued UTC)</span>
                    <div class="jobs-time-grid">
                        <label class="jobs-field">
                            <span>From</span>
                            <input class="jobs-input jobs-input--mono" type="datetime-local" value="@_enqueuedFromText" @oninput="SetEnqueuedFromText" />
                        </label>
                        <label class="jobs-field">
                            <span>To</span>
                            <input class="jobs-input jobs-input--mono" type="datetime-local" value="@_enqueuedToText" @oninput="SetEnqueuedToText" />
                        </label>
                    </div>
                </div>
            </div>

            <div class="jobs-query-panel__footer">
                <button class="jobs-execute-button" type="submit" disabled="@_isSearching">
                    <span class="material-symbols-outlined" aria-hidden="true">search</span>
                    <span>@(_isSearching ? "Running Query" : "Execute Query")</span>
                </button>
            </div>
        </form>
    </aside>

    <section class="jobs-results">
        <header class="jobs-toolbar">
            <div>
                <h1>Search Results</h1>
                @if (_page is not null)
                {
                    <p>@FormatResultRange()</p>
                }
            </div>

            <div class="jobs-toolbar__actions">
                <div class="sd-live-status @GetLiveStatusClass()" aria-live="polite">
                    <span class="sd-live-status__dot" aria-hidden="true"></span>
                    <span>@GetLiveStatusText(DateTimeOffset.UtcNow)</span>
                </div>
                <button class="jobs-toolbar-button @(_autoRefreshEnabled ? "jobs-toolbar-button--active" : null)" type="button" @onclick="ToggleAutoRefreshAsync" aria-pressed="@_autoRefreshEnabled">
                    <span class="material-symbols-outlined" aria-hidden="true">refresh</span>
                    <span>Auto-refresh: @(_autoRefreshEnabled ? "On" : "Off")</span>
                </button>
            </div>
        </header>

        @if (_error is not null)
        {
            <section class="jobs-message jobs-message--error" aria-live="polite">
                <span class="material-symbols-outlined" aria-hidden="true">error</span>
                <div>
                    <h2>Jobs failed to load</h2>
                    <p>@_error</p>
                </div>
            </section>
        }
        else if (_page is null)
        {
            <section class="jobs-message" aria-live="polite">
                <span class="material-symbols-outlined" aria-hidden="true">progress_activity</span>
                <div>
                    <h2>Loading jobs</h2>
                    <p>Reading scheduler job records.</p>
                </div>
            </section>
        }
        else
        {
            var nowUtc = DateTimeOffset.UtcNow;

            @if (_liveRefreshError is not null)
            {
                <section class="jobs-inline-alert jobs-inline-alert--error" aria-live="polite">
                    <span class="material-symbols-outlined" aria-hidden="true">warning</span>
                    <span>Auto-refresh failed: @_liveRefreshError</span>
                </section>
            }
            else if (_isRefreshing)
            {
                <section class="jobs-inline-alert" aria-live="polite">
                    <span class="material-symbols-outlined" aria-hidden="true">sync</span>
                    <span>Refreshing results</span>
                </section>
            }

            <div class="jobs-table-shell">
                <div class="jobs-table-wrap">
                    <table class="jobs-table">
                        <thead>
                            <tr>
                                <th>Job ID</th>
                                <th>State</th>
                                <th>Disposition</th>
                                <th>Handler</th>
                                <th class="jobs-table__number">Pri</th>
                                <th>Enqueued</th>
                                <th class="jobs-table__number">Att</th>
                                <th>Progress</th>
                                <th>Terminal Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_jobs.Count == 0)
                            {
                                <tr>
                                    <td class="jobs-empty-row" colspan="9">No jobs matched the current query.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var job in _jobs)
                                {
                                    <tr>
                                        <td>
                                            <a class="jobs-id-link" href="@CreateJobHref(job)">@FormatJobId(job.JobId)</a>
                                        </td>
                                        <td>
                                            <span class="jobs-state @GetStateBadgeClass(job.State)">
                                                <span aria-hidden="true"></span>
                                                @job.State
                                            </span>
                                        </td>
                                        <td>
                                            <span class="jobs-disposition @GetDispositionClass(job)" title="@FormatDisposition(job)">@FormatDisposition(job)</span>
                                        </td>
                                        <td>
                                            <span class="jobs-handler" title="@FormatFullHandler(job)">@FormatFullHandler(job)</span>
                                        </td>
                                        <td class="jobs-table__number">@job.Priority</td>
                                        <td>@RenderTimestampBlock(job.EnqueuedAtUtc, nowUtc)</td>
                                        <td class="jobs-table__number">@FormatAttempts(job)</td>
                                        <td>@RenderProgress(job.LatestProgress)</td>
                                        <td>@RenderTimestampBlock(GetTerminalTimestamp(job), nowUtc)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <footer class="jobs-pagination">
                    @if (_page.ContinuationToken is null)
                    {
                        <span>End of results</span>
                    }
                    else
                    {
                        <button class="jobs-load-more-button" type="button" @onclick="LoadMoreAsync" disabled="@_isLoadingMore">
                            @(_isLoadingMore ? "Loading Records" : "Load More Records")
                        </button>
                    }
                </footer>
            </div>
        }
    </section>
</div>

<style>
