    }

    .jobs-query-panel__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--sd-outline-variant);
        padding: 8px 16px;
    }

    .jobs-query-panel__body {
        display: flex;
        flex: 1 1 auto;
        min-height: 0;
        flex-direction: column;
        gap: 16px;
        overflow-y: auto;
        padding: 16px;
    }

    .jobs-query-panel__footer {
        border-top: 1px solid var(--sd-outline-variant);
        padding: 16px;
    }

    .jobs-field {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .jobs-field > span,
    .jobs-time-group__label {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .jobs-input {
        width: 100%;
        height: 32px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        color: var(--sd-on-surface);
        padding: 6px 8px;
        font-size: 12px;
        line-height: 16px;
    }

    .jobs-input--mono {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

