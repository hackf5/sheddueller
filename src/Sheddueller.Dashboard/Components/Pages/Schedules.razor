@page "/schedules"
@inherits DashboardPageComponent
@inject IScheduleInspectionReader Reader
@inject IRecurringScheduleManager ScheduleManager

<div class="schedules-page">
    <header class="schedules-header">
        <div>
            <h1>Schedules</h1>
            <p>Manage recurring operational tasks and cron triggers.</p>
        </div>
    </header>

    @if (_loadError is not null)
    {
        <section class="schedules-message schedules-message--error" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">error</span>
            <div>
                <h2>Schedules failed to load</h2>
                <p>@_loadError</p>
            </div>
        </section>
    }
    else if (_isLoading && _page is null)
    {
        <section class="schedules-message" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">progress_activity</span>
            <div>
                <h2>Loading schedules</h2>
                <p>Reading recurring schedule definitions.</p>
            </div>
        </section>
    }
    else
    {
        @if (LiveRefresh.RefreshError is not null)
        {
            <DashboardInlineAlert CssClass="schedules-inline-alert schedules-inline-alert--error" Icon="warning">
                <span>Refresh failed: @LiveRefresh.RefreshError</span>
            </DashboardInlineAlert>
        }

        @if (_actionMessage is not null)
        {
            <DashboardInlineAlert CssClass="@ActionAlertClass" Icon="@ActionAlertIcon">
                <span>@_actionMessage</span>
                @if (_triggeredJobId is { } triggeredJobId)
                {
                    <a class="schedules-action-alert__job" href="@JobHref(triggeredJobId)">@triggeredJobId.ToString("D")</a>
                }
            </DashboardInlineAlert>
        }

        <DashboardTableShell Title="Schedule Registry" ResultText="@ResultRangeText"
                             ShowLoadMore="@(_page?.ContinuationToken is not null)" IsLoadingMore="@_isLoadingMore"
                             OnLoadMore="LoadMoreAsync">
            <Toolbar>
                <select class="sd-table-select schedules-state-filter" aria-label="Filter by pause state"
                        value="@_filters.PauseState" @onchange="SetPauseStateFilterAsync">
                    <option value="">All States</option>
                    <option value="@DashboardScheduleFilters.ActiveStateFilter">Active</option>
                    <option value="@DashboardScheduleFilters.PausedStateFilter">Paused</option>
                </select>
                <DashboardSearchBox Value="@_filters.ScheduleKey" ValueChanged="SetScheduleKeyFilterAsync"
                                    Placeholder="Schedule key..." AriaLabel="Filter by exact schedule key" />
            </Toolbar>
            <ChildContent>
                <table class="schedules-table">
                    <colgroup>
                        <col class="schedules-table__col--key" />
                        <col class="schedules-table__col--state" />
                        <col class="schedules-table__col--handler" />
                        <col class="schedules-table__col--cron" />
                        <col class="schedules-table__col--timestamp" />
                        <col class="schedules-table__col--overlap" />
                        <col class="schedules-table__col--priority" />
                        <col class="schedules-table__col--metadata" />
                        <col class="schedules-table__col--timestamp" />
                        <col class="schedules-table__col--actions" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Schedule Key</th>
                            <th>State</th>
                            <th>Handler</th>
                            <th>Cron Exp.</th>
                            <th>Next Fire UTC</th>
                            <th>Overlap Mode</th>
                            <th class="schedules-table__number">Pri</th>
                            <th>Concurrency / Tags</th>
                            <th>Updated</th>
                            <th class="schedules-table__actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_schedules.Count == 0)
                        {
                            <tr>
                                <td class="schedules-empty-row" colspan="10">@EmptyText</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var schedule in _schedules)
                            {
                                <tr class="@ScheduleRowClass(schedule)" @key="schedule.ScheduleKey">
                                    <td>
                                        <span class="schedules-key" title="@schedule.ScheduleKey">@schedule.ScheduleKey</span>
                                    </td>
                                    <td>
                                        <span class="@ScheduleStateClass(schedule)">
                                            <span aria-hidden="true"></span>
                                            @ScheduleStateText(schedule)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="schedules-handler"
                                              title="@FullHandler(schedule)">@ShortHandler(schedule)</span>
                                    </td>
                                    <td>
                                        <span class="schedules-cron"
                                              title="@schedule.CronExpression">@schedule.CronExpression</span>
                                    </td>
                                    <td>
                                        <TimestampBlock BaseClass="schedules-timestamp" Value="schedule.NextFireAtUtc"
                                                        EmptyText="@NextFireEmptyText(schedule)" />
                                    </td>
                                    <td>
                                        <span class="@OverlapClass(schedule)">@schedule.OverlapMode</span>
                                    </td>
                                    <td class="schedules-table__number schedules-priority">@schedule.Priority</td>
                                    <td>
                                        <div class="schedules-metadata">
                                            <ChipList ClassPrefix="schedules-chip" Values="schedule.ConcurrencyGroupKeys"
                                                      Title="@DashboardFormat.GroupKeysTitle(schedule.ConcurrencyGroupKeys)"
                                                      EmptyText="No groups" />
                                            <TagChipList ClassPrefix="schedules-chip" Tags="schedule.Tags"
                                                         EmptyText="No tags" MaxVisible="2" />
                                        </div>
                                    </td>
                                    <td>
                                        <TimestampBlock BaseClass="schedules-timestamp" Value="schedule.UpdatedAtUtc"
                                                        AllowFutureRelative="false" />
                                    </td>
                                    <td>
                                        <div class="schedules-actions">
                                            <button class="schedules-icon-button" type="button" title="Trigger Now"
                                                    aria-label="@TriggerLabel(schedule)"
                                                    @onclick="@(() => TriggerNowAsync(schedule))" disabled="@IsActionDisabled">
                                                <span class="material-symbols-outlined" aria-hidden="true">play_arrow</span>
                                            </button>
                                            <button class="schedules-icon-button" type="button" title="@PauseResumeTitle(schedule)"
                                                    aria-label="@PauseResumeLabel(schedule)"
                                                    @onclick="@(() => PauseOrResumeAsync(schedule))" disabled="@IsActionDisabled">
                                                <span class="material-symbols-outlined"
                                                      aria-hidden="true">@PauseResumeIcon(schedule)</span>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </ChildContent>
        </DashboardTableShell>
    }
</div>

<style>
