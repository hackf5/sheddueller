@page "/concurrency-groups"
@inherits DashboardPageComponent
@inject IConcurrencyGroupInspectionReader Reader

<div class="groups-page">
    <header class="groups-header">
        <div>
            <h1>Concurrency Groups</h1>
            <p>Identify saturation and blocked work across resource pools.</p>
        </div>
    </header>

    @if (_loadError is not null)
    {
        <section class="groups-message groups-message--error" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">error</span>
            <div>
                <h2>Concurrency groups failed to load</h2>
                <p>@_loadError</p>
            </div>
        </section>
    }
    else if (_isLoading && _page is null)
    {
        <section class="groups-message" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">progress_activity</span>
            <div>
                <h2>Loading concurrency groups</h2>
                <p>Reading scheduler group occupancy and blocked work.</p>
            </div>
        </section>
    }
    else
    {
        var visibleGroups = FilteredGroups;

        @if (LiveRefresh.RefreshError is not null)
        {
            <DashboardInlineAlert CssClass="groups-inline-alert groups-inline-alert--error" Icon="warning">
                <span>Refresh failed: @LiveRefresh.RefreshError</span>
            </DashboardInlineAlert>
        }

        <DashboardTableShell Title="Group Registry" ResultText="@ResultRangeText" ShowLoadMore="@(_page?.ContinuationToken is not null)" IsLoadingMore="@_isLoadingMore" OnLoadMore="LoadMoreAsync">
            <Toolbar>
                <DashboardFilterSwitch Label="Saturated only" Checked="@_filters.SaturatedOnly" CheckedChanged="SetSaturatedOnlyAsync" Disabled="@_isLoading" />
                <DashboardFilterSwitch Label="Has blocked jobs" Checked="@_filters.HasBlockedJobsOnly" CheckedChanged="SetHasBlockedJobsOnlyAsync" Disabled="@_isLoading" />
                <DashboardSearchBox Value="@_filters.GroupKey" ValueChanged="SetGroupKeyFilter" Placeholder="Filter by group key..." AriaLabel="Filter by group key" />
            </Toolbar>
            <ChildContent>
                <table class="groups-table">
                    <colgroup>
                        <col class="groups-table__col--key" />
                        <col class="groups-table__col--number" />
                        <col class="groups-table__col--number" />
                        <col class="groups-table__col--number" />
                        <col class="groups-table__col--state" />
                        <col class="groups-table__col--timestamp" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Group Key</th>
                            <th class="groups-table__number">Effective Limit</th>
                            <th class="groups-table__number">Current Occupancy</th>
                            <th class="groups-table__number">Blocked Jobs</th>
                            <th>Saturation State</th>
                            <th>Last Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (visibleGroups.Count == 0)
                        {
                            <tr>
                                <td class="groups-empty-row" colspan="6">@EmptyText</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var group in visibleGroups)
                            {
                                <tr class="@GroupRowClass(group)" @key="group.GroupKey">
                                    <td>
                                        <span class="groups-key" title="@group.GroupKey">@group.GroupKey</span>
                                    </td>
                                    <td class="groups-table__number groups-count">@DashboardFormat.Count(group.EffectiveLimit)</td>
                                    <td class="groups-table__number groups-count">@DashboardFormat.Count(group.CurrentOccupancy)</td>
                                    <td class="groups-table__number">
                                        <span class="@BlockedCountClass(group)">@DashboardFormat.Count(group.BlockedJobCount)</span>
                                    </td>
                                    <td>
                                        <span class="@SaturationStateClass(group)">
                                            <span aria-hidden="true"></span>
                                            @SaturationStateText(group)
                                        </span>
                                    </td>
                                    <td><TimestampBlock BaseClass="groups-timestamp" Value="group.UpdatedAtUtc"
                                                        EmptyText="No updates" AllowFutureRelative="false" /></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </ChildContent>
        </DashboardTableShell>
    }
</div>

<style>
    .groups-page {
        display: flex;
        flex-direction: column;
        gap: var(--sd-gutter);
    }

    .groups-header {
        display: flex;
        align-items: center;
    }

    .groups-header {
        justify-content: space-between;
        gap: 16px;
    }

    .groups-header p {
        margin-top: 4px;
        color: var(--sd-on-surface-variant);
        font-size: 12px;
        line-height: 16px;
    }

    .groups-message,
    .groups-inline-alert {
        align-items: flex-start;
        gap: 12px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        padding: 16px;
    }

    .groups-message .material-symbols-outlined,
    .groups-inline-alert .material-symbols-outlined {
        color: var(--sd-primary);
    }

    .groups-message--error,
    .groups-inline-alert--error {
        border-color: var(--sd-error);
        background: var(--sd-error-container);
        color: var(--sd-on-error-container);
    }

    .groups-message--error .material-symbols-outlined,
    .groups-inline-alert--error .material-symbols-outlined {
        color: var(--sd-error);
    }

    .groups-message p,
    .groups-inline-alert {
        color: var(--sd-on-surface-variant);
    }

    .groups-inline-alert--error {
        color: var(--sd-on-error-container);
    }

    .groups-table {
        min-width: 1120px;
        table-layout: fixed;
        white-space: nowrap;
    }

    .groups-table__col--key {
        width: 320px;
    }

    .groups-table__col--number {
        width: 136px;
    }

    .groups-table__col--state {
        width: 176px;
    }

    .groups-table__col--timestamp {
        width: 204px;
    }

    .groups-table thead {
        position: sticky;
        top: 0;
        z-index: 1;
        background: var(--sd-surface-low);
    }

    .groups-table th,
    .groups-table td {
        border-bottom: 1px solid var(--sd-outline-variant);
        padding: 6px 8px;
        text-align: left;
        vertical-align: middle;
    }

    .groups-table th {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .groups-table td {
        height: 40px;
        color: var(--sd-on-surface);
        font-size: 12px;
        line-height: 16px;
    }

    .groups-table tbody tr:hover {
        background: var(--sd-surface-low);
    }

    .groups-row--saturated {
        background: color-mix(in srgb, var(--sd-error) 8%, transparent);
    }

    .groups-table__number {
        text-align: right;
    }

    .groups-key,
    .groups-count,
    .groups-blocked-count,
    .groups-timestamp__absolute {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .groups-key {
        display: block;
        overflow: hidden;
        color: var(--sd-primary);
        font-size: 13px;
        line-height: 18px;
        text-overflow: ellipsis;
    }

    .groups-blocked-count--attention {
        color: var(--sd-error);
        font-weight: 700;
    }

    .groups-state {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        padding: 2px 8px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .groups-state span {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: var(--sd-outline);
    }

    .groups-state--saturated {
        border-color: var(--sd-error);
        background: color-mix(in srgb, var(--sd-error) 14%, var(--sd-surface-lowest));
        color: var(--sd-error);
    }

    .groups-state--saturated span,
    .groups-state--blocked span {
        background: var(--sd-error);
    }

    .groups-state--blocked {
        border-color: var(--sd-error-container);
        background: var(--sd-surface-variant);
        color: var(--sd-error);
    }

    .groups-state--high {
        border-color: var(--sd-warning-container);
        background: var(--sd-warning-container);
        color: var(--sd-warning);
    }

    .groups-state--high span {
        background: var(--sd-warning);
    }

    .groups-state--nominal {
        background: var(--sd-surface-variant);
        color: var(--sd-on-surface-variant);
    }

    .groups-timestamp {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .groups-timestamp__relative {
        color: var(--sd-on-surface);
    }

    .groups-timestamp__absolute,
    .groups-empty-row {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        line-height: 16px;
    }

    .groups-empty-row {
        height: 96px;
        text-align: center;
    }

    @@media (max-width: 1120px) {
        .groups-header {
            align-items: stretch;
            flex-direction: column;
        }
    }
</style>

@code {
    private static readonly TimeSpan PageRefreshInterval = TimeSpan.FromSeconds(5);
    private const int DefaultPageSize = 25;

    private readonly List<ConcurrencyGroupInspectionSummary> _groups = [];
    private readonly DashboardConcurrencyGroupFilters _filters = new();
    private ConcurrencyGroupInspectionPage? _page;
    private string? _loadError;
    private bool _isLoading;
    private bool _isLoadingMore;

    private IReadOnlyList<ConcurrencyGroupInspectionSummary> FilteredGroups
      => this._filters.ApplyClientFilter(this._groups);

    private string EmptyText
      => this._groups.Count == 0
        ? "No concurrency groups matched the current query."
        : "No loaded concurrency groups matched the group key filter.";

    private string ResultRangeText
    {
        get
        {
            var loadedCount = this._groups.Count;
            var visibleCount = this.FilteredGroups.Count;
            var totalCount = this._page?.TotalCount ?? loadedCount;
            var filteredText = visibleCount == loadedCount
              ? string.Empty
              : string.Create(CultureInfo.InvariantCulture, $" ({DashboardFormat.Count(visibleCount)} visible after group key filter)");
            var moreText = this._page?.ContinuationToken is null ? string.Empty : " with more available";

            return loadedCount == 0
              ? string.Create(CultureInfo.InvariantCulture, $"Showing 0 of {DashboardFormat.Count(totalCount)} groups{filteredText}")
              : string.Create(CultureInfo.InvariantCulture, $"Showing 1-{DashboardFormat.Count(loadedCount)} of {DashboardFormat.Count(totalCount)} groups{filteredText}{moreText}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        this.InitializeLiveRefresh(
          this.RefreshCurrentQueryAsync,
          showRefreshing: false,
          lastUpdatedUtc: nowUtc => this.LiveRefresh.LastUpdatedUtc ?? (this._page is null ? null : nowUtc));

        await this.LoadAsync();
        this.StartPeriodicRefresh(PageRefreshInterval);
    }

    private async Task SetSaturatedOnlyAsync(bool value)
    {
        this._filters.SaturatedOnly = value;

        await this.LoadAsync();
    }

    private async Task SetHasBlockedJobsOnlyAsync(bool value)
    {
        this._filters.HasBlockedJobsOnly = value;

        await this.LoadAsync();
    }

    private void SetGroupKeyFilter(string value)
      => this._filters.GroupKey = value;

    private async Task LoadAsync()
    {
        this._loadError = null;
        this.LiveRefresh.ClearError();
        this._isLoading = true;

        try
        {
            var page = await Reader.SearchConcurrencyGroupsAsync(this._filters.ToQuery(DefaultPageSize, continuationToken: null));
            this.ReplaceGroups(page);
            this.LiveRefresh.MarkUpdated();
        }
        catch (Exception exception)
        {
            this._loadError = exception.Message;
        }
        finally
        {
            this._isLoading = false;
            this.NotifyShellRefreshChanged();
        }
    }

    private async Task LoadMoreAsync()
    {
        if (this._page?.ContinuationToken is null || this._isLoadingMore)
        {
            return;
        }

        this._loadError = null;
        this._isLoadingMore = true;

        try
        {
            var page = await Reader.SearchConcurrencyGroupsAsync(this._filters.ToQuery(DefaultPageSize, this._page.ContinuationToken));
            this._groups.AddRange(page.Groups);
            this._page = page;
            this.LiveRefresh.MarkUpdated();
        }
        catch (Exception exception)
        {
            this._loadError = exception.Message;
        }
        finally
        {
            this._isLoadingMore = false;
            this.NotifyShellRefreshChanged();
        }
    }

    private async Task RefreshCurrentQueryAsync(CancellationToken cancellationToken)
    {
        var visiblePageSize = Math.Max(DefaultPageSize, this._groups.Count);
        var page = await Reader.SearchConcurrencyGroupsAsync(
          this._filters.ToQuery(visiblePageSize, continuationToken: null),
          cancellationToken)
          ;

        await this.ApplyPageStateAsync(() => this.ReplaceGroups(page));
    }

    private void ReplaceGroups(ConcurrencyGroupInspectionPage page)
    {
        this._groups.Clear();
        this._groups.AddRange(page.Groups);
        this._page = page;
        this._loadError = null;
    }

    private static string GroupRowClass(ConcurrencyGroupInspectionSummary group)
      => group.IsSaturated ? "groups-row--saturated" : string.Empty;

    private static string BlockedCountClass(ConcurrencyGroupInspectionSummary group)
      => group.BlockedJobCount > 0 ? "groups-blocked-count groups-blocked-count--attention" : "groups-blocked-count";

    private static string SaturationStateText(ConcurrencyGroupInspectionSummary group)
    {
        if (group.IsSaturated)
        {
            return "Saturated";
        }

        if (group.BlockedJobCount > 0)
        {
            return "Blocked Work";
        }

        return GetOccupancyRatio(group) >= 0.8 ? "High Load" : "Nominal";
    }

    private static string SaturationStateClass(ConcurrencyGroupInspectionSummary group)
    {
        var modifier = group.IsSaturated
          ? "saturated"
          : group.BlockedJobCount > 0
            ? "blocked"
            : GetOccupancyRatio(group) >= 0.8
              ? "high"
              : "nominal";

        return string.Concat("groups-state groups-state--", modifier);
    }

    private static double GetOccupancyRatio(ConcurrencyGroupInspectionSummary group)
      => group.EffectiveLimit <= 0 ? 0 : (double)group.CurrentOccupancy / group.EffectiveLimit;
}
