@page "/nodes"
@inherits DashboardPageComponent
@inject INodeInspectionReader NodeReader
@inject IMetricsInspectionReader MetricsReader

<div class="nodes-page">
    <header class="nodes-header">
        <div>
            <h1>Nodes</h1>
            <p>Real-time liveness monitoring and local capacity tracking across the cluster.</p>
        </div>
    </header>

    @if (_loadError is not null)
    {
        <section class="nodes-message nodes-message--error" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">error</span>
            <div>
                <h2>Nodes failed to load</h2>
                <p>@_loadError</p>
            </div>
        </section>
    }
    else if (_isLoading && _nodePage is null)
    {
        <section class="nodes-message" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">progress_activity</span>
            <div>
                <h2>Loading nodes</h2>
                <p>Reading worker heartbeat records.</p>
            </div>
        </section>
    }
    else
    {
        var visibleNodes = FilteredNodes;

        <section class="nodes-summary-grid" aria-label="Node health summary">
            <article class="nodes-summary-card">
                <span class="nodes-summary-card__label">Total Nodes</span>
                <div>
                    <strong>@DashboardFormat.Count(TotalNodeCount)</strong>
                    <span>cluster-wide</span>
                </div>
            </article>
            <article class="nodes-summary-card">
                <span class="nodes-summary-card__label nodes-summary-card__label--active">
                    <span aria-hidden="true"></span>
                    Active
                </span>
                <div>
                    <strong>@DashboardFormat.Count(ActiveNodeCount)</strong>
                    <span>@HealthPercent(ActiveNodeCount)</span>
                </div>
            </article>
            <article class="nodes-summary-card">
                <span class="nodes-summary-card__label nodes-summary-card__label--stale">
                    <span aria-hidden="true"></span>
                    Stale
                </span>
                <div>
                    <strong>@DashboardFormat.Count(StaleNodeCount)</strong>
                    <span>missed heartbeat</span>
                </div>
            </article>
            <article class="nodes-summary-card nodes-summary-card--dead">
                <span class="nodes-summary-card__label nodes-summary-card__label--dead">
                    <span aria-hidden="true"></span>
                    Dead
                </span>
                <div>
                    <strong>@DashboardFormat.Count(DeadNodeCount)</strong>
                    <span>requires intervention</span>
                </div>
            </article>
        </section>

        @if (LiveRefresh.RefreshError is not null)
        {
            <DashboardInlineAlert CssClass="nodes-inline-alert nodes-inline-alert--error" Icon="warning">
                <span>Refresh failed: @LiveRefresh.RefreshError</span>
            </DashboardInlineAlert>
        }

        <DashboardTableShell Title="Node Registry" ResultText="@ResultRangeText"
                             ShowLoadMore="@(_nodePage?.ContinuationToken is not null)" IsLoadingMore="@_isLoadingMore"
                             OnLoadMore="LoadMoreAsync">
            <Toolbar>
                <select class="sd-table-select nodes-health-filter" aria-label="Filter by health state"
                        value="@_filters.State" @onchange="SetStateFilterAsync" disabled="@_isLoading">
                    <option value="">All States</option>
                    @foreach (var state in Enum.GetValues<NodeHealthState>())
                    {
                        <option value="@state">@state</option>
                    }
                </select>
                <DashboardSearchBox Value="@_filters.NodeId" ValueChanged="SetNodeIdFilter" Placeholder="Filter node ID..."
                                    AriaLabel="Filter node ID" />
            </Toolbar>
            <ChildContent>
                <table class="nodes-table">
                    <colgroup>
                        <col class="nodes-table__col--node" />
                        <col class="nodes-table__col--state" />
                        <col class="nodes-table__col--timestamp" />
                        <col class="nodes-table__col--timestamp" />
                        <col class="nodes-table__col--count" />
                        <col class="nodes-table__col--concurrency" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Node ID</th>
                            <th>Health State</th>
                            <th>First Seen</th>
                            <th>Last Heartbeat</th>
                            <th class="nodes-table__number">Claimed Jobs</th>
                            <th class="nodes-table__number">Local Concurrency</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (visibleNodes.Count == 0)
                        {
                            <tr>
                                <td class="nodes-empty-row" colspan="6">@EmptyText</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var node in visibleNodes)
                            {
                                <tr class="@NodeRowClass(node)" @key="node.NodeId">
                                    <td>
                                        <span class="nodes-id" title="@node.NodeId">@node.NodeId</span>
                                    </td>
                                    <td>
                                        <span class="@NodeStateClass(node.State)">
                                            <span aria-hidden="true"></span>
                                            @node.State
                                        </span>
                                    </td>
                                    <td>
                                        <TimestampBlock BaseClass="nodes-timestamp" Value="node.FirstSeenAtUtc"
                                                        AllowFutureRelative="false" />
                                    </td>
                                    <td>
                                        <TimestampBlock BaseClass="nodes-timestamp" Value="node.LastHeartbeatAtUtc"
                                                        AllowFutureRelative="false" />
                                    </td>
                                    <td class="nodes-table__number nodes-count">@DashboardFormat.Count(node.ClaimedJobCount)</td>
                                    <td>
                                        <div class="nodes-concurrency">
                                            <span class="nodes-concurrency__track" aria-hidden="true">
                                                <span class="@ConcurrencyBarClass(node)"
                                                      style="@ConcurrencyWidthStyle(node)"></span>
                                            </span>
                                            <span>@ConcurrencyText(node)</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </ChildContent>
        </DashboardTableShell>
    }
</div>

<style>
    .nodes-page {
        display: flex;
        flex-direction: column;
        gap: var(--sd-gutter);
    }

    .nodes-header,
    .nodes-summary-card div,
    .nodes-concurrency {
        display: flex;
        align-items: center;
    }

    .nodes-header {
        justify-content: space-between;
        gap: 16px;
    }

    .nodes-header p {
        margin-top: 4px;
        color: var(--sd-on-surface-variant);
        font-size: 12px;
        line-height: 16px;
    }

    .nodes-summary-card__label {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .nodes-message,
    .nodes-inline-alert {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        background: var(--sd-surface-lowest);
        padding: 16px;
    }

    .nodes-message .material-symbols-outlined,
    .nodes-inline-alert .material-symbols-outlined {
        color: var(--sd-primary);
    }

    .nodes-message--error,
    .nodes-inline-alert--error {
        border-color: var(--sd-error);
        background: var(--sd-error-container);
        color: var(--sd-on-error-container);
    }

    .nodes-message--error .material-symbols-outlined,
    .nodes-inline-alert--error .material-symbols-outlined {
        color: var(--sd-error);
    }

    .nodes-message p,
    .nodes-inline-alert {
        color: var(--sd-on-surface-variant);
    }

    .nodes-inline-alert--error {
        color: var(--sd-on-error-container);
    }

    .nodes-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--sd-gutter);
    }

    .nodes-summary-card {
        display: flex;
        min-height: 96px;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        border: 1px solid var(--sd-outline-variant);
        border-radius: var(--sd-radius);
        background: var(--sd-surface-lowest);
        padding: 16px;
    }

    .nodes-summary-card--dead {
        border-color: var(--sd-error-container);
        border-left: 4px solid var(--sd-error);
    }

    .nodes-summary-card__label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .nodes-summary-card__label span {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--sd-outline);
    }

    .nodes-summary-card__label--active span {
        background: var(--sd-secondary);
    }

    .nodes-summary-card__label--stale span {
        background: var(--sd-warning);
    }

    .nodes-summary-card__label--dead span {
        background: var(--sd-error);
    }

    .nodes-summary-card--dead strong {
        color: var(--sd-error);
    }

    .nodes-summary-card div {
        gap: 8px;
    }

    .nodes-summary-card strong {
        color: var(--sd-on-surface);
        font-family: "Space Grotesk", Inter, Arial, sans-serif;
        font-size: 24px;
        font-weight: 600;
        line-height: 32px;
    }

    .nodes-summary-card div span {
        color: var(--sd-on-surface-variant);
        font-size: 12px;
        line-height: 16px;
    }

    .nodes-health-filter {
        width: 152px;
    }

    .nodes-table {
        min-width: 1120px;
        table-layout: fixed;
        white-space: nowrap;
    }

    .nodes-table__col--node {
        width: 300px;
    }

    .nodes-table__col--state {
        width: 144px;
    }

    .nodes-table__col--timestamp {
        width: 184px;
    }

    .nodes-table__col--count {
        width: 128px;
    }

    .nodes-table__col--concurrency {
        width: 220px;
    }

    .nodes-table thead {
        position: sticky;
        top: 0;
        z-index: 1;
        background: var(--sd-surface-low);
    }

    .nodes-table th,
    .nodes-table td {
        border-bottom: 1px solid var(--sd-outline-variant);
        padding: 6px 8px;
        text-align: left;
        vertical-align: middle;
    }

    .nodes-table th {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .nodes-table td {
        height: 40px;
        color: var(--sd-on-surface);
        font-size: 12px;
        line-height: 16px;
    }

    .nodes-table tbody tr:hover {
        background: var(--sd-surface-low);
    }

    .nodes-row--stale {
        background: color-mix(in srgb, var(--sd-warning-container) 28%, transparent);
    }

    .nodes-row--dead {
        background: color-mix(in srgb, var(--sd-error) 10%, transparent);
    }

    .nodes-table__number {
        text-align: right;
    }

    .nodes-id,
    .nodes-count,
    .nodes-concurrency span:last-child,
    .nodes-timestamp__absolute {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }

    .nodes-id {
        display: block;
        overflow: hidden;
        color: var(--sd-primary);
        font-size: 13px;
        line-height: 18px;
        text-overflow: ellipsis;
    }

    .nodes-state {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--sd-outline-variant);
        border-radius: 2px;
        padding: 2px 8px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 12px;
        text-transform: uppercase;
    }

    .nodes-state span {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: var(--sd-outline);
    }

    .nodes-state--active {
        border-color: var(--sd-secondary-container);
        background: var(--sd-secondary-container);
        color: var(--sd-on-secondary-container);
    }

    .nodes-state--active span {
        background: var(--sd-secondary);
    }

    .nodes-state--stale {
        border-color: var(--sd-warning-container);
        background: var(--sd-warning-container);
        color: var(--sd-warning);
    }

    .nodes-state--stale span {
        background: var(--sd-warning);
    }

    .nodes-state--dead {
        border-color: var(--sd-error);
        background: color-mix(in srgb, var(--sd-error) 14%, var(--sd-surface-lowest));
        color: var(--sd-error);
    }

    .nodes-state--dead span {
        background: var(--sd-error);
    }

    .nodes-timestamp {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .nodes-timestamp__relative {
        color: var(--sd-on-surface);
    }

    .nodes-timestamp__absolute,
    .nodes-empty-row {
        color: var(--sd-on-surface-variant);
        font-size: 11px;
        line-height: 16px;
    }

    .nodes-concurrency {
        justify-content: flex-end;
        gap: 8px;
    }

    .nodes-concurrency__track {
        display: block;
        width: 72px;
        height: 6px;
        overflow: hidden;
        border-radius: 999px;
        background: var(--sd-surface-variant);
    }

    .nodes-concurrency__bar {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: var(--sd-secondary);
    }

    .nodes-concurrency__bar--hot {
        background: var(--sd-warning);
    }

    .nodes-concurrency__bar--inactive {
        background: var(--sd-outline-variant);
    }

    .nodes-empty-row {
        height: 96px;
        text-align: center;
    }

    @@media (max-width: 1120px) {
        .nodes-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .nodes-header {
            align-items: stretch;
            flex-direction: column;
        }
    }

    @@media (max-width: 720px) {
        .nodes-summary-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private static readonly TimeSpan PageRefreshInterval = TimeSpan.FromSeconds(5);
    private const int DefaultPageSize = 25;

    private readonly List<NodeInspectionSummary> _nodes = [];
    private readonly DashboardNodeFilters _filters = new();
    private NodeInspectionPage? _nodePage;
    private MetricsInspectionWindow? _metricsWindow;
    private string? _loadError;
    private bool _isLoading;
    private bool _isLoadingMore;

    private IReadOnlyList<NodeInspectionSummary> FilteredNodes
      => this._filters.ApplyClientFilter(this._nodes);

    private int ActiveNodeCount
      => this._metricsWindow?.ActiveNodeCount ?? this._nodes.Count(node => node.State == NodeHealthState.Active);

    private int StaleNodeCount
      => this._metricsWindow?.StaleNodeCount ?? this._nodes.Count(node => node.State == NodeHealthState.Stale);

    private int DeadNodeCount
      => this._metricsWindow?.DeadNodeCount ?? this._nodes.Count(node => node.State == NodeHealthState.Dead);

    private int TotalNodeCount
      => this.ActiveNodeCount + this.StaleNodeCount + this.DeadNodeCount;

    private string EmptyText
      => this._nodes.Count == 0
        ? "No worker nodes matched the current query."
        : "No loaded worker nodes matched the node ID filter.";

    private string ResultRangeText
    {
        get
        {
            var loadedCount = this._nodes.Count;
            var visibleCount = this.FilteredNodes.Count;
            var totalCount = this._nodePage?.TotalCount ?? Math.Max(this.TotalNodeCount, loadedCount);
            var filteredText = visibleCount == loadedCount
              ? string.Empty
              : string.Create(CultureInfo.InvariantCulture, $" ({DashboardFormat.Count(visibleCount)} visible after node ID filter)");

            return loadedCount == 0
              ? string.Create(CultureInfo.InvariantCulture, $"Showing 0 of {DashboardFormat.Count(totalCount)} nodes{filteredText}")
              : string.Create(CultureInfo.InvariantCulture, $"Showing 1-{DashboardFormat.Count(loadedCount)} of {DashboardFormat.Count(totalCount)} nodes{filteredText}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        this.InitializeLiveRefresh(
          this.RefreshCurrentQueryAsync,
          showRefreshing: false,
          lastUpdatedUtc: nowUtc => this.LiveRefresh.LastUpdatedUtc ?? (this._nodePage is null ? null : nowUtc));

        await this.LoadAsync();
        this.StartPeriodicRefresh(PageRefreshInterval);
    }

    private async Task SetStateFilterAsync(ChangeEventArgs eventArgs)
    {
        this._filters.State = eventArgs.Value?.ToString() ?? string.Empty;
        this._filters.NodeId = string.Empty;

        await this.LoadAsync();
    }

    private void SetNodeIdFilter(string value)
      => this._filters.NodeId = value;

    private async Task LoadAsync()
    {
        this._loadError = null;
        this.LiveRefresh.ClearError();
        this._isLoading = true;

        try
        {
            var snapshot = await this.ReadSnapshotAsync(
              continuationToken: null,
              pageSize: DefaultPageSize,
              CancellationToken.None)
              ;
            this.ApplySnapshot(snapshot, append: false);
            this.LiveRefresh.MarkUpdated();
        }
        catch (Exception exception)
        {
            this._loadError = exception.Message;
        }
        finally
        {
            this._isLoading = false;
            this.NotifyShellRefreshChanged();
        }
    }

    private async Task LoadMoreAsync()
    {
        if (this._nodePage?.ContinuationToken is null || this._isLoadingMore)
        {
            return;
        }

        this._loadError = null;
        this._isLoadingMore = true;

        try
        {
            var snapshot = await this.ReadSnapshotAsync(
              this._nodePage.ContinuationToken,
              DefaultPageSize,
              CancellationToken.None)
              ;
            this.ApplySnapshot(snapshot, append: true);
            this.LiveRefresh.MarkUpdated();
        }
        catch (Exception exception)
        {
            this._loadError = exception.Message;
        }
        finally
        {
            this._isLoadingMore = false;
            this.NotifyShellRefreshChanged();
        }
    }

    private async Task RefreshCurrentQueryAsync(CancellationToken cancellationToken)
    {
        var visiblePageSize = Math.Max(DefaultPageSize, this._nodes.Count);
        var snapshot = await this.ReadSnapshotAsync(
          continuationToken: null,
          pageSize: visiblePageSize,
          cancellationToken)
          ;

        await this.ApplyPageStateAsync(() => this.ApplySnapshot(snapshot, append: false));
    }

    private async Task<NodesSnapshot> ReadSnapshotAsync(
        string? continuationToken,
        int pageSize,
        CancellationToken cancellationToken)
    {
        var nodePageTask = NodeReader.SearchNodesAsync(
          this._filters.ToQuery(pageSize, continuationToken),
          cancellationToken)
          .AsTask();
        var metricsTask = MetricsReader.GetMetricsAsync(
          new MetricsInspectionQuery([TimeSpan.FromMinutes(5)]),
          cancellationToken)
          .AsTask();

        await Task.WhenAll(nodePageTask, metricsTask);

        return new NodesSnapshot(
          nodePageTask.Result,
          metricsTask.Result.Windows.FirstOrDefault());
    }

    private void ApplySnapshot(
        NodesSnapshot snapshot,
        bool append)
    {
        if (!append)
        {
            this._nodes.Clear();
        }

        this._nodes.AddRange(snapshot.Page.Nodes);
        this._nodePage = snapshot.Page;
        this._metricsWindow = snapshot.MetricsWindow;
        this._loadError = null;
    }

    private string HealthPercent(int count)
      => this.TotalNodeCount == 0
        ? "0%"
        : string.Create(CultureInfo.InvariantCulture, $"{((double)count / this.TotalNodeCount) * 100:0.#}%");

    private static string NodeRowClass(NodeInspectionSummary node)
      => node.State switch
      {
          NodeHealthState.Stale => "nodes-row--stale",
          NodeHealthState.Dead => "nodes-row--dead",
          _ => string.Empty,
      };

    private static string NodeStateClass(NodeHealthState state)
      => string.Concat("nodes-state nodes-state--", state.ToString().ToLowerInvariant());

    private static string ConcurrencyText(NodeInspectionSummary node)
      => string.Create(CultureInfo.InvariantCulture, $"{DashboardFormat.Count(node.CurrentExecutionCount)} / {DashboardFormat.Count(node.MaxConcurrentExecutionsPerNode)}");

    private static string ConcurrencyWidthStyle(NodeInspectionSummary node)
    {
        var percent = node.MaxConcurrentExecutionsPerNode <= 0
          ? 0
          : Math.Clamp((double)node.CurrentExecutionCount / node.MaxConcurrentExecutionsPerNode * 100, 0, 100);
        return string.Create(CultureInfo.InvariantCulture, $"width: {percent:0.##}%");
    }

    private static string ConcurrencyBarClass(NodeInspectionSummary node)
    {
        if (node.CurrentExecutionCount <= 0 || node.State != NodeHealthState.Active)
        {
            return "nodes-concurrency__bar nodes-concurrency__bar--inactive";
        }

        var usage = node.MaxConcurrentExecutionsPerNode <= 0
          ? 0
          : (double)node.CurrentExecutionCount / node.MaxConcurrentExecutionsPerNode;
        return usage >= 0.8
          ? "nodes-concurrency__bar nodes-concurrency__bar--hot"
          : "nodes-concurrency__bar";
    }

    private sealed record NodesSnapshot(
        NodeInspectionPage Page,
        MetricsInspectionWindow? MetricsWindow);
}
