<label class="sd-table-search">
    <span class="material-symbols-outlined" aria-hidden="true">search</span>
    <input type="search" placeholder="@Placeholder" aria-label="@AriaLabel" value="@Value" @oninput="HandleInputAsync" disabled="@Disabled" />
</label>

@code {
    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = string.Empty;

    [Parameter]
    public string AriaLabel { get; set; } = string.Empty;

    [Parameter]
    public bool Disabled { get; set; }

    private Task HandleInputAsync(ChangeEventArgs eventArgs)
      => ValueChanged.InvokeAsync(eventArgs.Value?.ToString() ?? string.Empty);
}
