{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "Sheddueller.slnx",
        "--configuration",
        "Release"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "--solution",
        "Sheddueller.slnx",
        "--configuration",
        "Release"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "format verify",
      "type": "process",
      "command": "dotnet",
      "args": [
        "format",
        "Sheddueller.slnx",
        "--verify-no-changes",
        "--verbosity",
        "minimal"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
