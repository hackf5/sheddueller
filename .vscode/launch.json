{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Sheddueller Sample Host",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/samples/Sheddueller.SampleHost/bin/Debug/net10.0/Sheddueller.SampleHost.dll",
      "args": [],
      "cwd": "${workspaceFolder}/samples/Sheddueller.SampleHost",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000"
      }
    }
  ]
}
