{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Sheddueller Sample Host",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/samples/Sheddueller.SampleHost/bin/Debug/net10.0/Sheddueller.SampleHost.dll",
      "args": [],
      "cwd": "${workspaceFolder}/samples/Sheddueller.SampleHost",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_HTTP_PORTS": "5000",
        "ASPNETCORE_CAPTURESTARTUPERRORS": "true"
      },
      "console": "internalConsole",
      "logging": {
        "moduleLoad": false
      }
    }
  ]
}